  document.getElementById('post-tags').value = '';
  
  // Summernote 에디터 초기화
  $('#summernote-editor').summernote('code', '');
  
  // 파일 입력 초기화
  document.getElementById('image-file-input').value = '';
}

// 카테고리 동적 로드
function loadCategories() {
  const categorySelect = document.getElementById('post-category');
  const posts = JSON.parse(localStorage.getItem('hamster_posts') || '[]');
  
  // 기존 카테고리 추출
  const existingCategories = new Set();
  posts.forEach(post => {
    if (post.category) {
      existingCategories.add(post.category);
    }
  });
  
  // 기본 카테고리와 기존 카테고리 결합
  const allCategories = [
    { value: 'txt', label: i18nData.write.categories.txt },
    { value: 'gallery', label: i18nData.write.categories.gallery },
    { value: 'archive', label: i18nData.write.categories.archive }
  ];
  
  // 기존 카테고리 추가 (중복 제거)
  Array.from(existingCategories).forEach(category => {
    if (!allCategories.find(cat => cat.value === category)) {
      const label = category === 'gallery' ? i18nData.write.categories.gallery : 
                   category === 'archive' ? i18nData.write.categories.archive : 
                   category === 'txt' ? i18nData.write.categories.txt : "";
      
      // 빈 라벨이 아닌 경우만 추가
      if (label !== "") {
        allCategories.push({ value: category, label: label });
      }
    }
  });
  
  // 셀렉트 옵션 업데이트
  categorySelect.innerHTML = allCategories.map(cat => 
    `<option value="${cat.value}">${cat.label}</option>`
  ).join('');
}

// 상단 메시지 표시
function showTopMessage(message) {
  // 기존 메시지 제거
  const existingMessage = document.getElementById('top-message');
  if (existingMessage) {
    existingMessage.remove();
  }
  
  // 새 메시지 생성
  const messageDiv = document.createElement('div');
  messageDiv.id = 'top-message';
  messageDiv.textContent = message;
  
  // body 맨 앞에 추가
  document.body.insertBefore(messageDiv, document.body.firstChild);
  
  // 트랜지션을 위해 약간의 지연 후 show 클래스 추가
  setTimeout(() => {
    messageDiv.classList.add('show');
  }, 10);
  
  // 1초 후 사라지는 애니메이션 시작
  setTimeout(() => {
    if (messageDiv.parentNode) {
      messageDiv.classList.remove('show');
      
      // 트랜지션 완료 후 제거
      setTimeout(() => {
        if (messageDiv.parentNode) {
          messageDiv.remove();
        }
      }, 300);
    }
  }, 2000);
}

// 자동 저장 기능 (1분 단위)
function setupAutoSave() {
  let autoSaveInterval;
  
  // 1분마다 자동 저장 (알림 없음)
  autoSaveInterval = setInterval(() => {
    // Summernote 내용을 textarea에 동기화
    syncSummernoteToTextarea();
    
    const content = document.getElementById('post-content').value;
    if (content.trim()) {
      saveDraft();
      // 알림 없이 조용히 저장
    }
  }, 60000); // 1분 = 60000ms
}

// 관리자 권한 체크 함수
function checkAdminPermission() {
  // AdminAuth 클래스가 정의되어 있는지 확인
  if (typeof AdminAuth !== 'undefined') {
    const adminAuth = new AdminAuth();
    return adminAuth.isAdminLoggedIn();
  }
  return false;
}

