// 커스텀 툴바 기능 초기화
function initializeCustomToolbar() {
  // HTML 보기 토글
  const htmlToggle = document.getElementById('chk_html');
  if (htmlToggle) {
    htmlToggle.addEventListener('change', function() {
      if (this.checked) {
        $('#summernote-editor').summernote('codeview.toggle');
      }
    });
  }

  // 글꼴 선택
  const fontDropdown = document.querySelector('.dropdown-fontname');
  if (fontDropdown) {
    const fontItems = fontDropdown.querySelectorAll('.note-dropdown-item');
    fontItems.forEach(item => {
      item.addEventListener('click', function(e) {
        e.preventDefault();
        const fontName = this.getAttribute('data-value');
        
        // Summernote에 글꼴 적용
        $('#summernote-editor').summernote('fontName', fontName);
        
        // 현재 선택된 글꼴 업데이트
        const currentFont = document.querySelector('.note-current-fontname');
        if (currentFont) {
          currentFont.textContent = fontName;
          currentFont.style.fontFamily = `'${fontName}'`;
        }
        
        // 체크 표시 업데이트
        fontItems.forEach(fontItem => fontItem.classList.remove('checked'));
        this.classList.add('checked');
      });
    });
  }

  // 글자 크기 선택
  const sizeDropdown = document.querySelector('.dropdown-fontsize');
  if (sizeDropdown) {
    const sizeItems = sizeDropdown.querySelectorAll('.note-dropdown-item');
    sizeItems.forEach(item => {
      item.addEventListener('click', function(e) {
        e.preventDefault();
        const fontSize = this.getAttribute('data-value');
        
        // Summernote에 글자 크기 적용
        $('#summernote-editor').summernote('fontSize', fontSize);
        
        // 현재 선택된 크기 업데이트
        const currentSize = document.querySelector('.note-current-fontsize');
        if (currentSize) {
          currentSize.textContent = fontSize;
        }
        
        // 체크 표시 업데이트
        sizeItems.forEach(sizeItem => sizeItem.classList.remove('checked'));
        this.classList.add('checked');
      });
    });
  }

  // 텍스트 스타일 버튼들
  const boldBtn = document.querySelector('.note-btn-bold');
  if (boldBtn) {
    boldBtn.addEventListener('click', function() {
      $('#summernote-editor').summernote('bold');
      this.classList.toggle('active');
    });
  }

  const italicBtn = document.querySelector('.note-btn-italic');
  if (italicBtn) {
    italicBtn.addEventListener('click', function() {
      $('#summernote-editor').summernote('italic');
      this.classList.toggle('active');
    });
  }

  const underlineBtn = document.querySelector('.note-btn-underline');
  if (underlineBtn) {
    underlineBtn.addEventListener('click', function() {
      $('#summernote-editor').summernote('underline');
      this.classList.toggle('active');
    });
  }

  const strikethroughBtn = document.querySelector('.note-btn-strikethrough');
  if (strikethroughBtn) {
    strikethroughBtn.addEventListener('click', function() {
      $('#summernote-editor').summernote('strikethrough');
      this.classList.toggle('active');
    });
  }

  const eraserBtn = document.querySelector('.note-icon-eraser').parentElement;
  if (eraserBtn) {
    eraserBtn.addEventListener('click', function() {
      $('#summernote-editor').summernote('removeFormat');
    });
  }

  // 색상 선택
  const colorBtns = document.querySelectorAll('.note-color-btn');
  colorBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      const color = this.getAttribute('data-value');
      const event = this.getAttribute('data-event');
      
      if (event === 'foreColor') {
        $('#summernote-editor').summernote('foreColor', color);
      } else if (event === 'backColor') {
        $('#summernote-editor').summernote('backColor', color);
      }
    });
  });

  // 표 삽입
  const tableBtn = document.querySelector('.note-icon-table').parentElement;
  if (tableBtn) {
    tableBtn.addEventListener('click', function() {
      // 간단한 표 삽입 (3x3)
      const tableHtml = '<table><tr><td></td><td></td><td></td></tr><tr><td></td><td></td><td></td></tr><tr><td></td><td></td><td></td></tr></table>';
      $('#summernote-editor').summernote('pasteHTML', tableHtml);
    });
  }

  // 문단 정렬
  const alignBtns = document.querySelectorAll('.note-align .note-btn');
  alignBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      const icon = this.querySelector('i');
      if (icon.classList.contains('note-icon-align-left')) {
        $('#summernote-editor').summernote('justifyLeft');
      } else if (icon.classList.contains('note-icon-align-center')) {
        $('#summernote-editor').summernote('justifyCenter');
      } else if (icon.classList.contains('note-icon-align-right')) {
        $('#summernote-editor').summernote('justifyRight');
      } else if (icon.classList.contains('note-icon-align-justify')) {
        $('#summernote-editor').summernote('justifyFull');
      }
    });
  });

  // 목록
  const unorderedListBtn = document.querySelector('.note-icon-unorderedlist').parentElement;
  if (unorderedListBtn) {
    unorderedListBtn.addEventListener('click', function() {
      $('#summernote-editor').summernote('insertUnorderedList');
