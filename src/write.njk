// Base64 이미지를 네오시티에 업로드하는 함수
async function processBase64Images(content) {
  if (!content || !content.ops) return content;
  
  const newOps = [];
  
  for (const op of content.ops) {
    if (op.insert && op.insert.image && op.insert.image.startsWith('data:image/')) {
      try {
        // Base64 이미지를 네오시티에 업로드
        const imageUrl = await uploadBase64ImageToNeocities(op.insert.image);
        
        newOps.push({
          insert: {
            image: imageUrl
          }
        });
        
        console.log('Image uploaded to Neocities:', imageUrl);
      } catch (error) {
        console.error('Failed to upload image to Neocities:', error);
        // 업로드 실패 시 원본 유지
        newOps.push(op);
      }
    } else {
      newOps.push(op);
    }
  }
  
  return { ...content, ops: newOps };
}

// Base64 이미지를 네오시티에 업로드
async function uploadBase64ImageToNeocities(base64Data) {
  const apiToken = neocitiesApiToken;
  const siteName = 'dakimakura';
  
  if (!apiToken) {
    throw new Error('Neocities API token not found');
  }
  
  // Base64 데이터를 Blob으로 변환
  const arr = base64Data.split(',');
  const mime = arr[0].match(/:(.*?);/)[1];
  const bstr = atob(arr[1]);
  let n = bstr.length;
  const u8arr = new Uint8Array(n);
  
  while (n--) {
    u8arr[n] = bstr.charCodeAt(n);
  }
  
  const blob = new Blob([u8arr], { type: mime });
  
  // 고유한 파일명 생성
  const timestamp = Date.now();
  const randomString = Math.random().toString(36).substring(2, 15);
  const extension = mime.split('/')[1];
  const fileName = `images/uploaded/${timestamp}_${randomString}.${extension}`;
  
  // FormData 생성
  const formData = new FormData();
  formData.append('file', blob, fileName);
  
  // 프록시 API로 업로드
  const response = await fetch('/api/neocities/upload', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      file: base64Data,
      filename: fileName
    })
  });
  
  if (!response.ok) {
    const errorData = await response.json();
    throw new Error(`Neocities upload failed: ${errorData.message || response.statusText}`);
  }
  
  // 상대 경로 반환 (dualImage 필터가 처리)
  return `/${fileName}`;
}

// Neocities에 이미지 업로드 (기존 함수)
async function uploadImageToNeocities(blob, mimeType) {
  const apiToken = neocitiesApiToken;
  const siteName = 'dakimakura';
  
  console.log('Neocities API Token:', apiToken ? 'Found' : 'Not found');
  console.log('Site Name:', siteName);
  
  if (!apiToken) {
    throw new Error('Neocities API token not found');
  }
  
  // 고유한 파일명 생성
  const timestamp = Date.now();
  const randomString = Math.random().toString(36).substring(2, 15);
  const extension = mimeType.split('/')[1];
  const fileName = `images/uploaded/${timestamp}_${randomString}.${extension}`;
  
  // FormData 생성
  const formData = new FormData();
  formData.append('file', blob, fileName);
  
  // 프록시 API 호출
  console.log('Uploading to Neocities via proxy:', fileName);
  const response = await fetch('/api/neocities/upload', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json'
    },
    body: JSON.stringify({
      file: base64Data,
      filename: fileName
    })
  });
  
  console.log('Upload response status:', response.status);
  
  if (!response.ok) {
    const errorData = await response.text();
    console.error('Upload failed:', response.status, errorData);
    throw new Error(`Upload failed: ${response.status} ${errorData}`);
  }
  
  const result = await response.json();
  console.log('Upload successful:', result);
  return `https://${siteName}.neocities.org/${fileName}`;
}

// Base64 이미지가 있는지 확인
function hasBase64Images(posts) {
  for (const post of posts) {
    if (post.description && post.description.ops) {
      for (const op of post.description.ops) {
        if (op.insert && op.insert.image && op.insert.image.startsWith('data:image/')) {
          return true;
        }
      }
    }
  }
  return false;
}








