// Base64 이미지를 처리하는 함수 (GitHub Actions에서 사용)
async function processBase64Images(content) {
  if (!content || !content.ops) return content;
  
  const newOps = [];
  
  for (const op of content.ops) {
    if (op.insert && op.insert.image && op.insert.image.startsWith('data:image/')) {
      // Base64 이미지는 그대로 유지 (GitHub Actions에서 처리)
      newOps.push(op);
    } else {
      newOps.push(op);
    }
  }
  
  return { ...content, ops: newOps };
}

// Base64 이미지가 있는지 확인
function hasBase64Images(posts) {
  for (const post of posts) {
    if (post.description && post.description.ops) {
      for (const op of post.description.ops) {
        if (op.insert && op.insert.image && op.insert.image.startsWith('data:image/')) {
          return true;
        }
      }
    }
  }
  return false;
}








// 임시저장 기능 (localStorage만 사용)
async function saveDraft() {
  try {
    // editor가 초기화되었는지 확인
    if (!editor) {
      console.log('에디터가 아직 초기화되지 않았습니다.');
      alert('에디터가 준비되지 않았습니다. 잠시 후 다시 시도해주세요.');
      return;
    }
    
    const content = editor.getContents();
    const tags = document.getElementById('post-tags').value;
    
    const draft = { 
      content, 
      tags,
      savedAt: new Date().toISOString() 
    };
    
    localStorage.setItem('write-draft', JSON.stringify(draft));
    showTopMessage('임시저장되었습니다. (로컬에만 저장)');
  } catch (error) {
    console.error('저장 중 오류:', error);
