  }
  
  // Summernote 에디터 초기화
  initializeSummernote();
  
  // 카테고리 로드
  loadCategories();
  
  // 이미지 업로드 설정
  setupImageUpload();
  
  // 태그 제안 설정
  setupTagSuggestions();
  
  // 자동 저장 설정
  setupAutoSave();
  
  // 버튼 이벤트 연결
  document.getElementById('save-draft-writer').addEventListener('click', saveDraft);
  document.getElementById('load-draft-writer').addEventListener('click', loadDraft);
  document.getElementById('save-post').addEventListener('click', savePost);
  
  // Undo/Redo 버튼 이벤트 연결
  document.getElementById('undo-btn').addEventListener('click', performUndo);
  document.getElementById('redo-btn').addEventListener('click', performRedo);
  
  // 키보드 단축키 설정
  setupKeyboardShortcuts();
  
  // 카테고리 변경 이벤트 (이제는 특별한 처리가 필요 없음)
  const categorySelect = document.getElementById('post-category');
  
  // 페이지 로드 시 임시저장 자동 불러오기
  const draft = JSON.parse(localStorage.getItem('write-draft') || '{}');
  if (draft.content) {
    loadDraft();
  }
  
  // 하루 글 작성 제한 체크 (관리자 권한이 있으면 제한 없음)
  // checkDailyPostLimit(); // 이 줄을 주석 처리하여 하루 제한 취소
});

// 하루 글 작성 제한 체크 함수
function checkDailyPostLimit() {
  // 개발자 모드 체크 (F12 또는 개발자 도구가 열려있는지 확인)
  const isDevMode = localStorage.getItem('dev-mode') === 'true' || 
                    window.outerHeight - window.innerHeight > 200; // 개발자 도구가 열려있으면 높이 차이가 큼
  
  if (isDevMode) {
    console.log('개발자 모드: 하루 글 작성 제한 비활성화');
    return; // 개발자 모드에서는 제한 없음
  }
  
  const today = new Date().toDateString();
  const lastPostDate = localStorage.getItem('last-post-date');
  
  if (lastPostDate === today) {
    // 오늘 이미 글을 작성했으면 폼 비활성화
    disableForm();
    showTopMessage(i18nData.write.messages.dailyLimitReached);
  }
}

// 폼 비활성화 함수
function disableForm() {
  const form = document.querySelector('.write-form');
  const inputs = form.querySelectorAll('input, textarea, select, button');
  
  inputs.forEach(input => {
    input.disabled = true;
    input.style.opacity = '0.5';
    input.style.cursor = 'not-allowed';
  });
  
  // 저장 버튼 숨기기
  const saveButton = document.getElementById('save-post');
  if (saveButton) {
    saveButton.style.display = 'none';
  }
  
  // 제한 메시지 표시
  const limitMessage = document.createElement('div');
  limitMessage.className = 'daily-limit-message';
  limitMessage.innerHTML = `
    <div style="text-align: center; padding: var(--spacing-lg); background: var(--bg-secondary); border-radius: var(--border-radius-sm); margin: var(--spacing-lg) 0;">
      <h3 style="color: var(--accent-primary); margin: 0 0 var(--spacing-sm) 0;">${i18nData.write.messages.dailyLimitTitle}</h3>
      <p style="color: var(--text-secondary); margin: 0;">${i18nData.write.messages.dailyLimitDescription}</p>
    </div>
  `;
  
  form.insertBefore(limitMessage, form.firstChild);
}

// 텍스트 영역 자동 크기 조정 함수
function setupTextareaAutoResize() {
  const textarea = document.getElementById('post-content');
  if (!textarea) return;
  
  function autoResize() {
    textarea.style.height = 'auto';
    textarea.style.height = textarea.scrollHeight + 'px';
  }
  
  // 초기 크기 설정
  autoResize();
  
  // 입력 시마다 크기 조정
  textarea.addEventListener('input', autoResize);
  textarea.addEventListener('paste', () => {
    setTimeout(autoResize, 10);
  });
}
</script>
