    }
    
    // Base64 мқҙлҜём§Җ мІҳлҰ¬ (NeocitiesлЎң м§Ғм ‘ м—…лЎңл“ң)
    showTopMessage('мқҙлҜём§ҖлҘј м—…лЎңл“ңн•ҳлҠ” мӨ‘...');
    let processedContent;
    try {
      processedContent = await processBase64Images(content);
    } catch (error) {
      console.error('мқҙлҜём§Җ м—…лЎңл“ң мӨ‘ мҳӨлҘҳ л°ңмғқ:', error);
      showTopMessage('мқҙлҜём§Җ м—…лЎңл“ң мӨ‘ мҳӨлҘҳк°Җ л°ңмғқн–ҲмҠөлӢҲлӢӨ. нҸ¬мҠӨнҠёлҠ” м ҖмһҘлҗҳм§Җл§Ң мқҙлҜём§ҖлҠ” base64лЎң мң м§Җлҗ©лӢҲлӢӨ.');
      processedContent = content; // мӣҗліё лӮҙмҡ© мӮ¬мҡ©
    }
    
    // кё°мЎҙ нҸ¬мҠӨнҠёл“Ө к°Җм ёмҳӨкё°
    const existingPosts = JSON.parse(localStorage.getItem('hamster_posts') || '[]');
    
    // мғҲ нҸ¬мҠӨнҠё мғқм„ұ
    const newPost = {
      id: Date.now(),
      date: new Date().toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\./g, '.').replace(/\s/g, ''),
      description: processedContent,
      tags: tags,
      createdAt: new Date().toISOString(),
      title: extractTitleFromContent(processedContent) || 'м ңлӘ© м—ҶмқҢ'
    };
    
    // мғҲ нҸ¬мҠӨнҠёлҘј кё°мЎҙ нҸ¬мҠӨнҠё лӘ©лЎқм—җ м¶”к°Җ
    existingPosts.push(newPost);
    
    // лЎңм»¬м—җ нҸ¬мҠӨнҠё м ҖмһҘ (GitHub Actionsк°Җ мІҳлҰ¬)
    localStorage.setItem('hamster_posts', JSON.stringify(existingPosts));
    
    // GitHub APIлҘј мӮ¬мҡ©н•ҳм—¬ posts.json нҢҢмқј м—…лҚ°мқҙнҠё (мӢӨм ң нҶ нҒ°мқҙ мһҲмқ„ л•Ңл§Ң)
    try {
      await updatePostsJsonFile(newPost);
      
      // мқҙлҜём§Җ м—…лЎңл“ң мҷ„лЈҢ м•ҢлҰј
      showTopMessage('мқҙлҜём§Җ м—…лЎңл“ңк°Җ мҷ„лЈҢлҗҳм—ҲмҠөлӢҲлӢӨ.');
    } catch (error) {
      console.warn('GitHub м ҖмһҘ мӢӨнҢЁ:', error);
      showTopMessage('лЎңм»¬м—җ м ҖмһҘлҗҳм—ҲмҠөлӢҲлӢӨ. GitHub н‘ёмӢң мӢң мһҗлҸҷмңјлЎң мІҳлҰ¬лҗ©лӢҲлӢӨ.');
    }
    
    // мҳӨлҠҳ лӮ м§ң кё°лЎқ (н•ҳлЈЁ м ңн•ң)
    const today = new Date().toDateString();
    localStorage.setItem('last-post-date', today);
    
    // м—җл””н„° мҙҲкё°нҷ”
    editor.setContents([]);
    document.getElementById('post-tags').value = '';
    
    console.log('New post saved:', newPost);
    showTopMessage(i18nData?.write?.messages?.saveSuccess || 'нҸ¬мҠӨнҠёк°Җ м ҖмһҘлҗҳм—ҲмҠөлӢҲлӢӨ.');
    
    // нҶөкі„ м—…лҚ°мқҙнҠё мқҙлІӨнҠё л°ңмғқ
    if (window.statsManager) {
      window.statsManager.updatePostCount();
    }
    window.dispatchEvent(new CustomEvent('postUpdated'));
    
    
  } catch (error) {
    console.error('Error saving:', error);
    showTopMessage('An error occurred while saving: ' + error.message);
  }
}

// Quill мҪҳн…җмё м—җм„ң м ңлӘ© м¶”м¶ң
function extractTitleFromContent(content) {
  if (!content || !content.ops) return null;
  
  // мІ« лІҲм§ё н…ҚмҠӨнҠё лё”лЎқм—җм„ң м ңлӘ© м¶”м¶ң
  for (const op of content.ops) {
    if (op.insert && typeof op.insert === 'string') {
      const text = op.insert.trim();
      if (text.length > 0) {
        // мІ« мӨ„мқ„ м ңлӘ©мңјлЎң мӮ¬мҡ© (50мһҗ м ңн•ң)
        return text.split('\n')[0].substring(0, 50);
      }
    }
  }
  return null;
}

// GitHub APIлҘј мӮ¬мҡ©н•ҳм—¬ posts.json нҢҢмқјм—җ мғҲ нҸ¬мҠӨнҠё м¶”к°Җ
async function updatePostsJsonFile(newPost) {
  try {
    // GitHub Personal Access Token нҷ•мқё
    const token = getGitHubToken();
    if (!token) {
      // нҶ нҒ°мқҙ м—Ҷмңјл©ҙ лЎңм»¬м—җл§Ң м ҖмһҘ
      console.warn('GitHub token not found. Saving locally only.');
      showTopMessage('GitHub token required. Saved locally only.');
      return;
    }

    // нҳ„мһ¬ нҢҢмқј лӮҙмҡ© к°Җм ёмҳӨкё°
    const response = await fetch('https://api.github.com/repos/sheepycrunch/sheepycrunch.github.io/contents/src/_data/posts.json', {
      method: 'GET',
      headers: {
        'Accept': 'application/vnd.github.v3+json',
        'Authorization': `token ${token}`,
      }
    });
    
    if (!response.ok) {
      throw new Error('нҢҢмқј м •ліҙ к°Җм ёмҳӨкё° мӢӨнҢЁ: ' + response.statusText);
    }
    
    const fileData = await response.json();
    
    // кё°мЎҙ нҸ¬мҠӨнҠёл“Ө к°Җм ёмҳӨкё° (UTF-8 л””мҪ”л”© мІҳлҰ¬)
    const base64Content = fileData.content;
    const binaryString = atob(base64Content);
    const bytes = new Uint8Array(binaryString.length);
    for (let i = 0; i < binaryString.length; i++) {
      bytes[i] = binaryString.charCodeAt(i);
    }
    const decoder = new TextDecoder('utf-8');
    const jsonString = decoder.decode(bytes);
    const existingContent = JSON.parse(jsonString);
    const existingPosts = existingContent.posts || [];
    
    // мғҲ нҸ¬мҠӨнҠёлҘј л§Ё м•һм—җ м¶”к°Җ
    const updatedPosts = [newPost, ...existingPosts];
    
    // мғҲ нҢҢмқј лӮҙмҡ© мғқм„ұ (UTF-8 мқёмҪ”л”© мІҳлҰ¬)
    const newContent = JSON.stringify({ posts: updatedPosts }, null, 2);
    
    // UTF-8 мқёмҪ”л”©мқ„ мң„н•ң TextEncoder мӮ¬мҡ©
    const encoder = new TextEncoder();
    const utf8Bytes = encoder.encode(newContent);
    const encodedContent = btoa(String.fromCharCode(...utf8Bytes));
    
    // нҢҢмқј м—…лҚ°мқҙнҠё
    const updateResponse = await fetch('https://api.github.com/repos/sheepycrunch/sheepycrunch.github.io/contents/src/_data/posts.json', {
      method: 'PUT',
      headers: {
        'Accept': 'application/vnd.github.v3+json',
        'Authorization': `token ${token}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        message: `Add new post: ${newPost.title} at ${new Date().toISOString()}`,
        content: encodedContent,
        sha: fileData.sha
      })
    });
    
    if (!updateResponse.ok) {
      const errorData = await updateResponse.json();
      throw new Error('нҢҢмқј м—…лҚ°мқҙнҠё мӢӨнҢЁ: ' + (errorData.message || updateResponse.statusText));
    }
    
    console.log('posts.json file successfully updated.');
    
  } catch (error) {
    console.error('GitHub API update failed:', error);
    throw error;
  }
}

// GitHub Personal Access Token к°Җм ёмҳӨкё°
function getGitHubToken() {
  // 1. Eleventyм—җм„ң мЈјмһ…лҗң м „м—ӯ лҚ°мқҙн„°м—җм„ң нҶ нҒ° нҷ•мқё
  if (window.githubToken && window.githubToken !== 'undefined' && window.githubToken !== 'null' && window.githubToken.trim() !== '') {
    console.log('Using GitHub token from Eleventy injection.');
    return window.githubToken;
  }
  
  // 2. localStorageм—җм„ң нҶ нҒ° нҷ•мқё (л°ұм—…)
  let token = localStorage.getItem('github_token');
  
  if (!token) {
    console.warn('GitHub token not configured. Please check AUTHOR_TOKEN environment variable.');
    return null;
  }
  
  return token;
}



// мғҒлӢЁ л©”мӢңм§Җ н‘ңмӢң
function showTopMessage(message) {
  // кё°мЎҙ л©”мӢңм§Җ м ңкұ°
  const existingMessage = document.getElementById('top-message');
  if (existingMessage) {
    existingMessage.remove();
  }
  
  // мғҲ л©”мӢңм§Җ мғқм„ұ
  const messageDiv = document.createElement('div');
  messageDiv.id = 'top-message';
  messageDiv.textContent = message;
  
  // body л§Ё м•һм—җ м¶”к°Җ
  document.body.insertBefore(messageDiv, document.body.firstChild);
  
  // нҠёлһңм§Җм…ҳмқ„ мң„н•ҙ м•Ҫк°„мқҳ м§Җм—° нӣ„ show нҒҙлһҳмҠӨ м¶”к°Җ
  setTimeout(() => {
    messageDiv.classList.add('show');
  }, 10);
  
  // 1мҙҲ нӣ„ мӮ¬лқјм§ҖлҠ” м• лӢҲл©”мқҙм…ҳ мӢңмһ‘
  setTimeout(() => {
    if (messageDiv.parentNode) {
      messageDiv.classList.remove('show');
      
      // нҠёлһңм§Җм…ҳ мҷ„лЈҢ нӣ„ м ңкұ°
      setTimeout(() => {
        if (messageDiv.parentNode) {
          messageDiv.remove();
        }
      }, 300);
    }
  }, 2000);
}

// мһҗлҸҷ м ҖмһҘ кё°лҠҘ (1л¶„ лӢЁмң„)
function setupAutoSave() {
  let autoSaveInterval;
  
  // 1л¶„л§ҲлӢӨ мһҗлҸҷ м ҖмһҘ (м•ҢлҰј м—ҶмқҢ)
  autoSaveInterval = setInterval(async () => {
    try {
      const content = editor.getContents();
      if (content && content.ops && content.ops.length > 0) {
        saveDraft();
        // м•ҢлҰј м—Ҷмқҙ мЎ°мҡ©нһҲ м ҖмһҘ
      }
    } catch (error) {
      console.error('Auto-save error:', error);
    }
  }, 60000); // 1л¶„ = 60000ms
}

// кҙҖлҰ¬мһҗ к¶Ңн•ң мІҙнҒ¬ н•ЁмҲҳ
function checkAdminPermission() {
  // AdminAuth нҒҙлһҳмҠӨк°Җ м •мқҳлҗҳм–ҙ мһҲлҠ”м§Җ нҷ•мқё
  if (typeof AdminAuth !== 'undefined') {
    const adminAuth = new AdminAuth();
    return adminAuth.isAdminLoggedIn();
  }
  return false;
}

// к¶Ңн•ңмқҙ м—Ҷмңјл©ҙ 404 нҺҳмқҙм§ҖлЎң лҰ¬лӢӨмқҙл үнҠё
function redirectToLogin() {
  window.location.href = '/login.html';
}



// Quill.js м—җл””н„° мҙҲкё°нҷ”
let editor;

function initializeQuillJS() {
  // Quill.jsк°Җ лЎңл“ңлҗҳм—ҲлҠ”м§Җ нҷ•мқё
  if (typeof Quill === 'undefined') {
    console.error('Quill.js not loaded.');
    return;
  }

  editor = new Quill('#post-content', {
    theme: 'snow',
    bounds: '#post-content',
    modules: {
      toolbar: [
        [{ 'font': ['Noto Sans CJK KR', 'Apple SD Gothic Neo', 'Malgun Gothic', 'л§‘мқҖ кі л”•', 'Arial'] }],
        [{ 'header': [1, 2, 3, false] }],
        [{ 'size': ['small', false, 'large', 'huge'] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ 'color': [] }, { 'background': [] }],
        [{ 'align': [] }, { 'list': 'ordered'}, { 'list': 'bullet' }],
        ['link', 'image']
      ]
    }
  });

  // м—җл””н„° лӮҙмҡ©мқҙ ліҖкІҪлҗ  л•Ңл§ҲлӢӨ мқҙлІӨнҠё л°ңмғқ
  editor.on('text-change', function() {
    document.getElementById('post-content').dispatchEvent(new Event('input', { bubbles: true }));
  });


  console.log('Quill.js successfully initialized.');
}


// мқҙлІӨнҠё лҰ¬мҠӨл„Ҳ м„Өм •
document.addEventListener('DOMContentLoaded', function() {
  // кҙҖлҰ¬мһҗ к¶Ңн•ң мІҙнҒ¬
  if (!checkAdminPermission()) {
    redirectToLogin();
    return;
  }
  
  // Quill.js м—җл””н„° мҙҲкё°нҷ” (м•Ҫк°„мқҳ м§Җм—°мқ„ л‘җм–ҙ CDN лЎңл”© мҷ„лЈҢ нӣ„ мӢӨн–ү)
  setTimeout(() => {
    initializeQuillJS();
  }, 100);
  
  // м№ҙн…Ңкі лҰ¬ лЎңл“ң (л№„нҷңм„ұнҷ”)
  // loadCategories();
  
  // нғңк·ё м ңм•Ҳ м„Өм •
  setupTagSuggestions();
  
  // мқҙлҜём§Җ м—…лЎңл“ң м„Өм •
  setupImageUpload();
  
  // мһҗлҸҷ м ҖмһҘ м„Өм •
  setupAutoSave();
  
  
  // лІ„нҠј мқҙлІӨнҠё м—°кІ°
  document.getElementById('save-draft-writer').addEventListener('click', saveDraft);
  document.getElementById('load-draft-writer').addEventListener('click', loadDraft);
  document.getElementById('save-post').addEventListener('click', savePost);
  
  // нҺҳмқҙм§Җ лЎңл“ң мӢң мһ„мӢңм ҖмһҘ мһҗлҸҷ л¶Ҳлҹ¬мҳӨкё°
  const draft = JSON.parse(localStorage.getItem('write-draft') || '{}');
  if (draft.content) {
    loadDraft();
  }
  
});



</script>
