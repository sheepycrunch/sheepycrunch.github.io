<link href="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-bs4.min.css" rel="stylesheet" type="text/css" media="all">

<!-- jQuery and Summernote JS -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/summernote@0.8.20/dist/summernote-bs4.min.js"></script>

<script>
// AdminAuth 클래스 로드 (login.njk에서 정의된 것과 동일)
class AdminAuth {
  constructor() {
    // 환경변수에서 관리자 키 가져오기 (빌드 시점에 주입됨)
    this.adminKey = window.ADMIN_SECRET_KEY || 'DEFAULT_FALLBACK_KEY';
    this.sessionKey = 'admin_session';
    this.expiresKey = 'admin_expires';
  }
  
  verifyAdminKey(inputKey) {
    // 한글 키 지원을 위한 정규화
    const normalizedInput = this.normalizeKey(inputKey);
    const normalizedAdminKey = this.normalizeKey(this.adminKey);
    
    return normalizedInput === normalizedAdminKey;
  }
  
  // 키 정규화 함수 (한글 키 지원)
  normalizeKey(key) {
    if (!key) return '';
    
    // 공백만 제거하고 특수문자는 유지 (느낌표 등이 키의 일부일 수 있음)
    return key.toString()
      .trim()                    // 앞뒤 공백 제거
      .replace(/\s+/g, '');      // 중간 공백만 제거
  }
  
  setAdminSession() {
    const sessionToken = this.generateSessionToken();
    const expires = Date.now() + (24 * 60 * 60 * 1000);
    
    localStorage.setItem(this.sessionKey, sessionToken);
    localStorage.setItem(this.expiresKey, expires.toString());
    
    return sessionToken;
  }
  
  generateSessionToken() {
    const timestamp = Date.now();
    const random = Math.random().toString(36).substring(2);
    return btoa(`${timestamp}_${random}_ADMIN`).replace(/[+/=]/g, '');
  }
  
  isAdminLoggedIn() {
    const session = localStorage.getItem(this.sessionKey);
    const expires = localStorage.getItem(this.expiresKey);
    
    if (!session || !expires) return false;
    if (Date.now() > parseInt(expires)) {
      this.logout();
      return false;
    }
    return true;
  }
  
  logout() {
    localStorage.removeItem(this.sessionKey);
    localStorage.removeItem(this.expiresKey);
  }
}

// 전역으로 사용할 수 있도록 설정
window.AdminAuth = AdminAuth;

// i18n 데이터를 JavaScript에서 사용할 수 있도록 전역 변수 설정
const i18nData = JSON.parse(document.getElementById('i18n-data').textContent);

// Summernote 에디터에 이미지 드래그 앤 드랍 기능 추가
function setupImageUpload() {
  const summernoteEditor = document.getElementById('summernote-editor');
  const fileInput = document.getElementById('image-file-input');
  
  // Summernote 에디터에 드래그 앤 드랍 이벤트 추가
  summernoteEditor.addEventListener('dragover', (e) => {
    e.preventDefault();
    summernoteEditor.classList.add('dragover');
  });
  
  summernoteEditor.addEventListener('dragleave', () => {
    summernoteEditor.classList.remove('dragover');
  });
  
  summernoteEditor.addEventListener('drop', (e) => {
    e.preventDefault();
    summernoteEditor.classList.remove('dragover');
    
    const files = e.dataTransfer.files;
    if (files.length > 0 && files[0].type.startsWith('image/')) {
      handleImageFile(files[0]);
    }
  });
  
  // 클릭으로 파일 선택
  summernoteEditor.addEventListener('click', () => {
    fileInput.click();
  });
  
  fileInput.addEventListener('change', (e) => {
    if (e.target.files.length > 0) {
      handleImageFile(e.target.files[0]);
    }
  });
  
  function handleImageFile(file) {
    if (!file.type.startsWith('image/')) {
      alert(i18nData.write.messages.imageOnly);
      return;
    }
    
    const reader = new FileReader();
    reader.onload = (e) => {
      // Summernote 에디터에 이미지 삽입
      $('#summernote-editor').summernote('insertImage', e.target.result);
    };
    reader.readAsDataURL(file);
  }
}


// 임시저장 기능 (admin-panel.js 스타일)
function saveDraft() {
  // Summernote 내용을 textarea에 동기화
  syncSummernoteToTextarea();
  
  const content = document.getElementById('post-content').value;
  const tags = document.getElementById('post-tags').value;
  const category = document.getElementById('post-category').value;
  
  const draft = { 
    content, 
    tags, 
    category,
    savedAt: new Date().toISOString() 
  };
  
  localStorage.setItem('write-draft', JSON.stringify(draft));
  showTopMessage(i18nData.write.messages.draftSaved);
}

// 임시저장 불러오기 (admin-panel.js 스타일)
function loadDraft() {
