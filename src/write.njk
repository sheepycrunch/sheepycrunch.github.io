---
layout: layout.njk
title: "글 작성"
description: "글 작성"
lang: "en"
permalink: "/write.html"
---

<section id="content">
  <h2>{{ "글 작성" | t(lang) }}</h2>
  
  <div id="i18n-data" style="display: none;">{{ i18n | dump | safe }}</div>
  <div class="form-group">
    <label>{{ "내용" | t(lang) }}</label>
    
    
    <div class="editor-container">
      <div id="post-content"></div>
    </div>
    <input type="file" id="image-file-input" accept="image/*" style="display: none;" />
  </div>
  
  <div class="form-group">
    <label for="post-tags">{{ "태그 (영어만)" | t(lang) }}</label>
    <input type="text" id="post-tags" class="form-input" placeholder="{{ "예: daily, thoughts, review" | t(lang) }}" />
    <div class="tag-suggestions" id="tag-suggestions"></div>
  </div>
  
  <div class="writer-actions">
    <div class="save-controls">
      <button id="save-draft-writer" class="button secondary">{{ "임시저장" | t(lang) }}</button>
      <button id="load-draft-writer" class="button secondary">{{ "임시저장 불러오기" | t(lang) }}</button>
      <button id="save-post" class="button">{{ "저장" | t(lang) }}</button>
    </div>
  </div>
</section>


<!-- Quill.js JavaScript -->
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>
<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">


<!-- Cloudinary Upload Widget -->
<script src="https://upload-widget.cloudinary.com/global/all.js" type="text/javascript"></script>

<script>
// AdminAuth 클래스 로드 (login.njk에서 정의된 것과 동일)
class AdminAuth {
  constructor() {
    // 환경변수에서 관리자 키 가져오기 (빌드 시점에 주입됨)
    this.adminKey = window.ADMIN_SECRET_KEY || 'DEFAULT_FALLBACK_KEY';
    this.sessionKey = 'admin_session';
    this.expiresKey = 'admin_expires';
  }
  
  verifyAdminKey(inputKey) {
    // 한글 키 지원을 위한 정규화
    const normalizedInput = this.normalizeKey(inputKey);
    const normalizedAdminKey = this.normalizeKey(this.adminKey);
    
    return normalizedInput === normalizedAdminKey;
  }
  
  // 키 정규화 함수 (한글 키 지원)
  normalizeKey(key) {
    if (!key) return '';
    
    // 공백만 제거하고 특수문자는 유지 (느낌표 등이 키의 일부일 수 있음)
    return key.toString()
      .trim()                    // 앞뒤 공백 제거
      .replace(/\s+/g, '');      // 중간 공백만 제거
  }
  
  setAdminSession() {
    const sessionToken = this.generateSessionToken();
    const expires = Date.now() + (24 * 60 * 60 * 1000);
    
    localStorage.setItem(this.sessionKey, sessionToken);
    localStorage.setItem(this.expiresKey, expires.toString());
    
    return sessionToken;
  }
  
  generateSessionToken() {
    const timestamp = Date.now();
    const random = Math.random().toString(36).substring(2);
    return btoa(`${timestamp}_${random}_ADMIN`).replace(/[+/=]/g, '');
  }
  
  isAdminLoggedIn() {
    const session = localStorage.getItem(this.sessionKey);
    const expires = localStorage.getItem(this.expiresKey);
    
    if (!session || !expires) return false;
    if (Date.now() > parseInt(expires)) {
      this.logout();
      return false;
    }
    return true;
  }
  
  logout() {
    localStorage.removeItem(this.sessionKey);
    localStorage.removeItem(this.expiresKey);
  }
}

// 전역으로 사용할 수 있도록 설정
window.AdminAuth = AdminAuth;

// i18n 데이터를 JavaScript에서 사용할 수 있도록 전역 변수 설정
const i18nData = JSON.parse(document.getElementById('i18n-data').textContent);

// Cloudinary 설정
const CLOUDINARY_CONFIG = {
  cloudName: 'dlcrkgyzd',
  uploadPreset: 'default'
};

// 이미지 편집 모달 관련 변수
let cropModal = null;

// Base64 이미지 마이그레이션 관련 변수
let migrationInProgress = false;

// 이미지 드래그 앤 드랍 기능
function setupImageUpload() {
  const editorContainer = document.querySelector('.editor-container');
  const fileInput = document.getElementById('image-file-input');
  
  console.log('setupImageUpload 함수가 호출되었습니다.');
  console.log('editorContainer:', editorContainer);
  console.log('fileInput:', fileInput);
  
  // 전체 페이지에 드래그 앤 드랍 이벤트 추가 (더 확실한 방법)
  document.addEventListener('dragover', (e) => {
    e.preventDefault();
    console.log('페이지 전체 드래그 오버');
  });
  
  document.addEventListener('drop', (e) => {
    e.preventDefault();
    console.log('페이지 전체 드롭 이벤트');
    
    // 에디터 영역 내부인지 확인
    const quillEditor = document.querySelector('.ql-editor');
    if (quillEditor && quillEditor.contains(e.target)) {
      console.log('에디터 영역에서 드롭 감지');
      
      const files = e.dataTransfer.files;
      if (files.length > 0 && files[0].type.startsWith('image/')) {
        console.log('이미지 파일 감지:', files[0].name);
        handleImageFile(files[0]);
      } else {
        console.log('이미지가 아닌 파일입니다.');
        alert(i18nData?.write?.messages?.imageOnly || '이미지 파일만 업로드할 수 있습니다.');
      }
    }
  });
  
  // Quill 에디터가 완전히 로드된 후에 클릭 이벤트 등록
  function attachClickEvents() {
    const quillEditor = document.querySelector('.ql-editor');
    
    if (!quillEditor) {
      console.log('Quill 에디터가 아직 로드되지 않았습니다. 1초 후 다시 시도합니다.');
      setTimeout(attachClickEvents, 1000);
      return;
    }
    
    console.log('클릭 이벤트를 등록합니다.');
    
    // 클릭으로 파일 선택 기능 비활성화 (드래그 앤 드랍만 사용)
    // quillEditor.addEventListener('click', (e) => {
    //   // 툴바 버튼 클릭이 아닌 경우에만 파일 선택 다이얼로그 열기
    //   if (!e.target.closest('.ql-toolbar')) {
    //     console.log('에디터 영역 클릭 - 파일 선택 다이얼로그 열기');
    //     fileInput.click();
    //   }
    // });
  }
  
  // 파일 입력 이벤트
  fileInput.addEventListener('change', (e) => {
    if (e.target.files.length > 0) {
      console.log('파일 선택됨:', e.target.files[0].name);
      handleImageFile(e.target.files[0]);
    }
  });
  
  function handleImageFile(file) {
    console.log('handleImageFile 호출됨:', file.name, file.type);
    
    if (!file.type.startsWith('image/')) {
      alert(i18nData.write.messages.imageOnly);
      return;
    }
    
    console.log('이미지 파일 처리 시작:', file.name);
    
    // Cloudinary에 직접 업로드
    uploadToCloudinary(file);
  }

  // 모달 닫기
  function closeCropModal() {
    if (cropModal) {
      cropModal.remove();
      cropModal = null;
    }
  }

  // 에디터에 이미지 삽입
  function insertImageToEditor(imageDataURL) {
    try {
      const range = editor.getSelection();
      const index = range ? range.index : editor.getLength();
      
      editor.insertEmbed(index, 'image', imageDataURL);
      editor.setSelection(index + 1);
      
      console.log('이미지가 성공적으로 삽입되었습니다.');
    } catch (error) {
      console.error('이미지 삽입 중 오류:', error);
      alert('이미지 삽입 중 오류가 발생했습니다.');
    }
  }

  // Cloudinary에 이미지 업로드 (Transform API 사용)
  function uploadToCloudinary(file) {
    // Cloudinary 설정이 기본값인지 확인
    if (CLOUDINARY_CONFIG.cloudName === 'your_cloud_name' || 
        CLOUDINARY_CONFIG.uploadPreset === 'your_upload_preset') {
      console.log('Cloudinary 설정이 필요합니다. Base64로 저장합니다.');
      showTopMessage('Cloudinary 설정이 필요합니다. 로컬 이미지로 저장됩니다.');
      
      // Base64로 저장
      const reader = new FileReader();
      reader.onload = (e) => {
        insertImageToEditor(e.target.result);
      };
      reader.readAsDataURL(file);
      return;
    }
    
    const formData = new FormData();
    formData.append('file', file);
    formData.append('upload_preset', CLOUDINARY_CONFIG.uploadPreset);
    
    // 업로드 중 표시
    showTopMessage('이미지 업로드 중...');
    
    fetch(`https://api.cloudinary.com/v1_1/${CLOUDINARY_CONFIG.cloudName}/image/upload`, {
      method: 'POST',
      body: formData
    })
    .then(response => response.json())
    .then(data => {
      if (data.secure_url) {
        // 업로드 성공 시 이미지 편집 모달 표시
        showImageEditModal(data);
        showTopMessage('이미지가 업로드되었습니다. 편집하세요.');
      } else {
        throw new Error('업로드 실패');
      }
    })
    .catch(error => {
      console.error('Cloudinary 업로드 오류:', error);
      showTopMessage('Cloudinary 업로드에 실패했습니다. 로컬 이미지로 저장됩니다.');
      
      // 실패 시 Base64로 저장
      const reader = new FileReader();
      reader.onload = (e) => {
        insertImageToEditor(e.target.result);
      };
      reader.readAsDataURL(file);
    });
  }

  // 이미지 편집 모달 표시 (Transform API 사용)
  function showImageEditModal(cloudinaryData) {
    // 기존 모달이 있으면 제거
    if (cropModal) {
      cropModal.remove();
    }
    
    const originalUrl = cloudinaryData.secure_url;
    const publicId = cloudinaryData.public_id;
    
    // 모달 HTML 생성
    cropModal = document.createElement('div');
    cropModal.id = 'crop-modal';
    cropModal.innerHTML = `
      <div class="crop-modal-overlay">
        <div class="crop-modal-content">
          <div class="crop-modal-header">
            <h3>이미지 편집</h3>
            <button class="crop-modal-close">&times;</button>
          </div>
          <div class="crop-modal-body">
            <div class="image-preview-container">
              <img id="original-image" src="${originalUrl}" alt="Original Image" style="max-width: 100%; max-height: 300px;">
            </div>
            <div class="transform-controls">
              <div class="control-group">
                <label>크기:</label>
                <select id="size-preset">
                  <option value="w_auto,h_auto">원본 크기</option>
                  <option value="w_400,h_auto">작은 크기 (400px)</option>
                  <option value="w_800,h_auto">중간 크기 (800px)</option>
                  <option value="w_1200,h_auto">큰 크기 (1200px)</option>
                  <option value="w_400,h_300,c_fill">정사각형 (400x300)</option>
                  <option value="w_800,h_600,c_fill">정사각형 (800x600)</option>
                </select>
              </div>
              <div class="control-group">
                <label>품질:</label>
                <select id="quality-preset">
                  <option value="q_auto">자동</option>
                  <option value="q_80">고품질 (80%)</option>
                  <option value="q_60">중품질 (60%)</option>
                  <option value="q_40">저품질 (40%)</option>
                </select>
              </div>
              <div class="control-group">
                <label>포맷:</label>
                <select id="format-preset">
                  <option value="f_auto">자동</option>
                  <option value="f_jpg">JPG</option>
                  <option value="f_png">PNG</option>
                  <option value="f_webp">WebP</option>
                </select>
              </div>
              <div class="control-group">
                <label>효과:</label>
                <select id="effect-preset">
                  <option value="">효과 없음</option>
                  <option value="e_grayscale">흑백</option>
                  <option value="e_sepia">세피아</option>
                  <option value="e_negate">반전</option>
                  <option value="e_art:audrey">아트 효과</option>
                </select>
              </div>
            </div>
            <div class="preview-container">
              <h4>미리보기:</h4>
              <img id="preview-image" src="${originalUrl}" alt="Preview" style="max-width: 100%; max-height: 200px; border: 1px solid #ddd;">
            </div>
          </div>
          <div class="crop-modal-footer">
            <button id="crop-cancel" class="button secondary">취소</button>
            <button id="crop-apply" class="button primary">적용</button>
          </div>
        </div>
      </div>
    `;
    
    // 모달을 body에 추가
    document.body.appendChild(cropModal);
    
    // 이벤트 리스너 추가
    setupImageEditModalEvents(originalUrl, publicId);
  }

  // 이미지 편집 모달 이벤트 설정
  function setupImageEditModalEvents(originalUrl, publicId) {
    // 닫기 버튼
    document.querySelector('.crop-modal-close').addEventListener('click', closeCropModal);
    document.getElementById('crop-cancel').addEventListener('click', closeCropModal);
    
    // 적용 버튼
    document.getElementById('crop-apply').addEventListener('click', () => {
      const finalUrl = generateTransformUrl(originalUrl, publicId);
      insertImageToEditor(finalUrl);
      closeCropModal();
      showTopMessage('이미지가 적용되었습니다.');
    });
    
    // 실시간 미리보기 업데이트
    const controls = ['size-preset', 'quality-preset', 'format-preset', 'effect-preset'];
    controls.forEach(controlId => {
      document.getElementById(controlId).addEventListener('change', () => {
        updatePreview(originalUrl, publicId);
      });
    });
    
    // 초기 미리보기 설정
    updatePreview(originalUrl, publicId);
  }

  // Transform URL 생성
  function generateTransformUrl(originalUrl, publicId) {
    const size = document.getElementById('size-preset').value;
    const quality = document.getElementById('quality-preset').value;
    const format = document.getElementById('format-preset').value;
    const effect = document.getElementById('effect-preset').value;
    
    // Transform 파라미터 조합
    const transforms = [size, quality, format, effect].filter(t => t).join(',');
    
    if (transforms) {
      // Cloudinary Transform URL 생성
      const baseUrl = `https://res.cloudinary.com/${CLOUDINARY_CONFIG.cloudName}/image/upload`;
      return `${baseUrl}/${transforms}/${publicId}`;
    }
    
    return originalUrl;
  }

  // 미리보기 업데이트
  function updatePreview(originalUrl, publicId) {
    const previewUrl = generateTransformUrl(originalUrl, publicId);
    const previewImg = document.getElementById('preview-image');
    previewImg.src = previewUrl;
  }

  // Base64 이미지를 Cloudinary로 마이그레이션
  async function migrateBase64ImagesToCloudinary() {
    if (migrationInProgress) {
      console.log('마이그레이션이 이미 진행 중입니다.');
      return;
    }

    migrationInProgress = true;
    showTopMessage('Base64 이미지를 Cloudinary로 마이그레이션 중...');

    try {
      // 모든 포스트에서 Base64 이미지 찾기
      const posts = JSON.parse(localStorage.getItem('hamster_posts') || '[]');
      let migratedCount = 0;
      let totalImages = 0;

      // Base64 이미지 개수 계산
      for (const post of posts) {
        if (post.description && post.description.ops) {
          for (const op of post.description.ops) {
            if (op.insert && op.insert.image && op.insert.image.startsWith('data:image/')) {
              totalImages++;
            }
          }
        }
      }

      if (totalImages === 0) {
        showTopMessage('마이그레이션할 Base64 이미지가 없습니다.');
        migrationInProgress = false;
        return;
      }

      console.log(`총 ${totalImages}개의 Base64 이미지를 마이그레이션합니다.`);

      // 각 포스트의 Base64 이미지를 Cloudinary로 업로드
      for (let i = 0; i < posts.length; i++) {
        const post = posts[i];
        if (post.description && post.description.ops) {
          const newOps = [];
          
          for (const op of post.description.ops) {
            if (op.insert && op.insert.image && op.insert.image.startsWith('data:image/')) {
              try {
                // Base64를 Blob으로 변환
                const blob = await base64ToBlob(op.insert.image);
                
                // Cloudinary에 업로드
                const cloudinaryUrl = await uploadBlobToCloudinary(blob);
                
                // 새로운 op 생성 (Cloudinary URL 사용)
                newOps.push({
                  insert: {
                    image: cloudinaryUrl
                  }
                });
                
                migratedCount++;
                console.log(`이미지 ${migratedCount}/${totalImages} 마이그레이션 완료`);
                
                // 진행률 표시
                showTopMessage(`마이그레이션 진행 중... ${migratedCount}/${totalImages}`);
                
              } catch (error) {
                console.error('이미지 마이그레이션 실패:', error);
                // 실패한 경우 원본 유지
                newOps.push(op);
              }
            } else {
              newOps.push(op);
            }
          }
          
          // 업데이트된 ops로 포스트 수정
          posts[i].description.ops = newOps;
        }
      }

      // 업데이트된 포스트들을 localStorage에 저장
      localStorage.setItem('hamster_posts', JSON.stringify(posts));
      
      // GitHub에도 업데이트 (선택사항)
      try {
        await updatePostsJsonFile(posts);
      } catch (error) {
        console.warn('GitHub 업데이트 실패:', error);
      }

      showTopMessage(`마이그레이션 완료! ${migratedCount}개의 이미지가 Cloudinary로 이동되었습니다.`);
      
    } catch (error) {
      console.error('마이그레이션 중 오류:', error);
      showTopMessage('마이그레이션 중 오류가 발생했습니다.');
    } finally {
      migrationInProgress = false;
    }
  }

  // Base64를 Blob으로 변환
  function base64ToBlob(base64Data) {
    return new Promise((resolve, reject) => {
      const arr = base64Data.split(',');
      const mime = arr[0].match(/:(.*?);/)[1];
      const bstr = atob(arr[1]);
      let n = bstr.length;
      const u8arr = new Uint8Array(n);
      
      while (n--) {
        u8arr[n] = bstr.charCodeAt(n);
      }
      
      resolve(new Blob([u8arr], { type: mime }));
    });
  }

  // Blob을 Cloudinary에 업로드
  async function uploadBlobToCloudinary(blob) {
    const formData = new FormData();
    formData.append('file', blob);
    formData.append('upload_preset', CLOUDINARY_CONFIG.uploadPreset);
    
    const response = await fetch(`https://api.cloudinary.com/v1_1/${CLOUDINARY_CONFIG.cloudName}/image/upload`, {
      method: 'POST',
      body: formData
    });
    
    if (!response.ok) {
      throw new Error(`Cloudinary 업로드 실패: ${response.statusText}`);
    }
    
    const data = await response.json();
    return data.secure_url;
  }

  // Base64 이미지가 있는지 확인
  function hasBase64Images() {
    const posts = JSON.parse(localStorage.getItem('hamster_posts') || '[]');
    
    for (const post of posts) {
      if (post.description && post.description.ops) {
        for (const op of post.description.ops) {
          if (op.insert && op.insert.image && op.insert.image.startsWith('data:image/')) {
            return true;
          }
        }
      }
    }
    
    return false;
  }

  // 마이그레이션 버튼 표시
  function showMigrationButton() {
    if (hasBase64Images() && !migrationInProgress) {
      // 기존 마이그레이션 버튼이 있으면 제거
      const existingBtn = document.getElementById('migration-button');
      if (existingBtn) {
        existingBtn.remove();
      }
      
      // 마이그레이션 버튼 생성
      const migrationBtn = document.createElement('button');
      migrationBtn.id = 'migration-button';
      migrationBtn.className = 'button';
      migrationBtn.textContent = 'Base64 이미지를 Cloudinary로 마이그레이션';
      migrationBtn.style.marginTop = '10px';
      migrationBtn.style.backgroundColor = 'var(--accent-secondary)';
      
      migrationBtn.addEventListener('click', migrateBase64ImagesToCloudinary);
      
      // 버튼을 적절한 위치에 추가
      const writerActions = document.querySelector('.writer-actions');
      if (writerActions) {
        writerActions.appendChild(migrationBtn);
      }
    }
  }
  
  // 클릭 이벤트 등록 시작
  attachClickEvents();
}

// 이미지 편집 모달 CSS 스타일 추가 (기존 디자인 시스템 사용)
function addCropModalStyles() {
