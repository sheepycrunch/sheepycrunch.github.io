      if (url) {
        $('#summernote-editor').summernote('createLink', url);
      }
    });
  }
}

// Summernote 에디터 초기화
function initializeSummernote() {
  $('#summernote-editor').summernote({
    height: 300,
    minHeight: 200,
    maxHeight: 500,
    focus: false,
    lang: 'ko-KR',
    toolbar: false, // 기본 툴바 비활성화
    fontNames: [
      '맑은 고딕', '굴림체', '굴림', '바탕체', '바탕', '궁서',
      '나눔고딕', 'Helvetica', 'Arial', 'Arial Black', 'Comic Sans MS',
      'Courier New', 'Impact', 'Tahoma', 'Times New Roman', 'Verdana'
    ],
    fontSizes: ['8', '9', '10', '11', '12', '14', '16', '18', '20', '22', '24', '28', '30', '36', '50', '72', '96'],
    callbacks: {
      onChange: function(contents, $editable) {
        // Summernote 내용이 변경될 때마다 숨겨진 textarea에 동기화
        $('#post-content').val(contents);
        // undo/redo 버튼 상태 업데이트
        updateUndoRedoButtons();
      },
      onInit: function() {
        // 에디터 초기화 완료 후 기존 내용 로드
        const existingContent = $('#post-content').val();
        if (existingContent) {
          $('#summernote-editor').summernote('code', existingContent);
        }
        // 초기 버튼 상태 설정
        updateUndoRedoButtons();
        
        // 커스텀 툴바 초기화
        initializeCustomToolbar();
      }
    }
  });
}

// Summernote 내용을 textarea에 동기화하는 함수
function syncSummernoteToTextarea() {
  const content = $('#summernote-editor').summernote('code');
  $('#post-content').val(content);
}

// textarea 내용을 Summernote에 동기화하는 함수
function syncTextareaToSummernote() {
  const content = $('#post-content').val();
  $('#summernote-editor').summernote('code', content);
}

// Undo/Redo 기능 함수들
function performUndo() {
  $('#summernote-editor').summernote('undo');
  updateUndoRedoButtons();
}

function performRedo() {
  $('#summernote-editor').summernote('redo');
  updateUndoRedoButtons();
}

// Undo/Redo 버튼 상태 업데이트
function updateUndoRedoButtons() {
  const undoBtn = document.getElementById('undo-btn');
  const redoBtn = document.getElementById('redo-btn');
  
  if (undoBtn && redoBtn) {
    // Summernote의 undo/redo 히스토리 상태 확인
    const editor = $('#summernote-editor');
    const undoAvailable = editor.summernote('isUndoable');
    const redoAvailable = editor.summernote('isRedoable');
    
    // 버튼 활성화/비활성화
    undoBtn.disabled = !undoAvailable;
    redoBtn.disabled = !redoAvailable;
    
    // 시각적 피드백
    if (undoAvailable) {
      undoBtn.classList.remove('disabled');
    } else {
      undoBtn.classList.add('disabled');
    }
    
    if (redoAvailable) {
      redoBtn.classList.remove('disabled');
    } else {
      redoBtn.classList.add('disabled');
    }
  }
}

// 키보드 단축키 설정
function setupKeyboardShortcuts() {
  document.addEventListener('keydown', function(e) {
    // Ctrl+Z (Undo)
    if (e.ctrlKey && e.key === 'z' && !e.shiftKey) {
      e.preventDefault();
      performUndo();
    }
    // Ctrl+Y 또는 Ctrl+Shift+Z (Redo)
    else if ((e.ctrlKey && e.key === 'y') || (e.ctrlKey && e.shiftKey && e.key === 'z')) {
      e.preventDefault();
      performRedo();
    }
  });
}

// 이벤트 리스너 설정
document.addEventListener('DOMContentLoaded', function() {
  // 관리자 권한 체크
  if (!checkAdminPermission()) {
    redirectTo404();
