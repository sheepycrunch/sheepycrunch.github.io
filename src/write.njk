    <div class="save-controls">
      <button id="save-draft-writer" class="button secondary">{{ "임시저장" | t(lang) }}</button>
      <button id="load-draft-writer" class="button secondary">{{ "임시저장 불러오기" | t(lang) }}</button>
      <button id="save-post" class="button">{{ "저장" | t(lang) }}</button>
    </div>
  </div>
</section>


