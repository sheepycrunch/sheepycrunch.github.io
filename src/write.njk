// 임시저장 불러오기
async function loadDraft() {
  const draft = JSON.parse(localStorage.getItem('write-draft') || '{}');
  
  if (draft.content) {
    try {
      // editor가 초기화되었는지 확인
      if (!editor) {
        console.log('에디터가 아직 초기화되지 않았습니다. 1초 후 다시 시도합니다.');
        setTimeout(loadDraft, 1000);
        return;
      }
      
      editor.setContents(draft.content);
      document.getElementById('post-tags').value = draft.tags || '';
      
      // 상단 메시지 표시
      showTopMessage(i18nData?.write?.messages?.draftLoaded || '임시저장된 내용을 불러왔습니다.');
    } catch (error) {
      console.error('불러오기 중 오류:', error);
      showTopMessage('불러오기 중 오류가 발생했습니다.');
    }
  } else {
    showTopMessage(i18nData?.write?.messages?.noDraft || '임시저장된 내용이 없습니다.');
  }
}

// 태그 제안 기능 (기존 태그에서 추출)
function setupTagSuggestions() {
  const tagInput = document.getElementById('post-tags');
  const suggestions = document.getElementById('tag-suggestions');
  
  // 기존 포스트에서 모든 태그 추출
  function getAllExistingTags() {
    const posts = JSON.parse(localStorage.getItem('hamster_posts') || '[]');
    const allTags = new Set();
    
    console.log('전체 포스트 데이터:', posts);
    
    posts.forEach(post => {
      console.log('포스트 태그:', post.tags, '타입:', typeof post.tags);
      if (post.tags) {
        if (Array.isArray(post.tags)) {
          // 배열인 경우
          post.tags.forEach(tag => {
            if (tag && tag.trim()) {
              allTags.add(tag.trim());
            }
          });
        } else if (typeof post.tags === 'string') {
          // 문자열인 경우 (쉼표로 구분)
          const tags = post.tags.split(',').map(tag => tag.trim()).filter(tag => tag);
          tags.forEach(tag => allTags.add(tag));
        }
      }
    });
    
    console.log('추출된 태그들:', Array.from(allTags));
    return Array.from(allTags);
  }
  
  // 기존 태그 표시
  function showExistingTags() {
    const existingTags = getAllExistingTags();
    if (existingTags.length > 0) {
      suggestions.innerHTML = `
        <div class="existing-tags-list">
          ${existingTags.map(tag => 
            `<span class="tag-button" onclick="addTag('${tag}')">${tag}</span>`
          ).join('')}
        </div>
      `;
      suggestions.style.display = 'block';
    } else {
      suggestions.innerHTML = `
        <div class="existing-tags-title">${i18nData?.write?.messages?.existingTags || '기존 태그'}</div>
        <div class="no-results">${i18nData?.write?.messages?.noTagsAvailable || '사용 가능한 태그가 없습니다.'}</div>
      `;
      suggestions.style.display = 'block';
    }
  }
  
  // 초기 로드 시 기존 태그 표시 (항상 보이도록)
  showExistingTags();
  
  tagInput.addEventListener('input', () => {
    const value = tagInput.value.toLowerCase();
    const existingTags = getAllExistingTags();
    const currentTags = tagInput.value.split(',').map(t => t.trim()).filter(t => t);
    
    if (value.length > 0) {
      const filteredTags = existingTags.filter(tag => 
        tag.toLowerCase().includes(value) && !currentTags.includes(tag)
      );
      
      if (filteredTags.length > 0) {
        suggestions.innerHTML = `
          <div class="filtered-tags-title">${i18nData?.write?.messages?.searchResults || '검색 결과:'}</div>
          <div class="filtered-tags-list">
            ${filteredTags.slice(0, 10).map(tag => 
              `<span class="tag-button" onclick="addTag('${tag}')">${tag}</span>`
            ).join('')}
          </div>
        `;
        suggestions.style.display = 'block';
      } else {
        suggestions.innerHTML = `<div class="no-results">${i18nData?.write?.messages?.noResults || '검색 결과가 없습니다.'}</div>`;
        suggestions.style.display = 'block';
      }
    } else {
      showExistingTags();
    }
  });
  
  // 포커스 시 기존 태그 다시 표시
  tagInput.addEventListener('focus', () => {
    showExistingTags();
  });
}

function addTag(tag) {
  const tagInput = document.getElementById('post-tags');
  const currentTags = tagInput.value.split(',').map(t => t.trim()).filter(t => t);
  
  if (!currentTags.includes(tag)) {
    currentTags.push(tag);
    tagInput.value = currentTags.join(', ');
  }
  
  document.getElementById('tag-suggestions').style.display = 'none';
  tagInput.focus();
}


async function savePost() {
  try {
    // editor가 초기화되었는지 확인
    if (!editor) {
      console.log('에디터가 아직 초기화되지 않았습니다.');
      alert('에디터가 준비되지 않았습니다. 잠시 후 다시 시도해주세요.');
      return;
    }
    
    const content = editor.getContents();
    const tags = document.getElementById('post-tags').value.split(',').map(tag => tag.trim()).filter(tag => tag);
    
    if (!content || !content.ops || content.ops.length === 0) {
      showTopMessage(i18nData?.write?.messages?.noContent || '내용을 입력해주세요.');
      return;
    }
    
    // Base64 이미지 처리 (GitHub Actions에서 Neocities로 업로드)
    const processedContent = await processBase64Images(content);
    
    // 기존 포스트들 가져오기
    const existingPosts = JSON.parse(localStorage.getItem('hamster_posts') || '[]');
    
    // 새 포스트 생성
    const newPost = {
      id: Date.now(),
      date: new Date().toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\./g, '.').replace(/\s/g, ''),
      description: processedContent,
      tags: tags,
      createdAt: new Date().toISOString(),
      title: extractTitleFromContent(processedContent) || '제목 없음'
    };
    
    // 새 포스트를 기존 포스트 목록에 추가
    existingPosts.push(newPost);
    
    // 로컬에 포스트 저장 (GitHub Actions가 처리)
    localStorage.setItem('hamster_posts', JSON.stringify(existingPosts));
    
    // GitHub API를 사용하여 posts.json 파일 업데이트 (실제 토큰이 있을 때만)
    try {
      await updatePostsJsonFile(newPost);
      
      // Base64 이미지가 있는 경우 알림
      if (hasBase64Images([newPost])) {
        showTopMessage('Base64 이미지가 감지되었습니다. GitHub 푸시 시 자동으로 Neocities에 업로드됩니다.');
      }
    } catch (error) {
      console.warn('GitHub 저장 실패:', error);
      showTopMessage('로컬에 저장되었습니다. GitHub 푸시 시 자동으로 처리됩니다.');
    }
    
    // 오늘 날짜 기록 (하루 제한)
    const today = new Date().toDateString();
    localStorage.setItem('last-post-date', today);
    
    // 에디터 초기화
    editor.setContents([]);
    document.getElementById('post-tags').value = '';
    
    console.log('새 포스트 저장됨:', newPost);
    showTopMessage(i18nData?.write?.messages?.saveSuccess || '포스트가 저장되었습니다.');
    
    // 통계 업데이트 이벤트 발생
    if (window.statsManager) {
      window.statsManager.updatePostCount();
    }
    window.dispatchEvent(new CustomEvent('postUpdated'));
    
    
  } catch (error) {
    console.error('저장 중 오류:', error);
    showTopMessage('저장 중 오류가 발생했습니다: ' + error.message);
  }
}

// Quill 콘텐츠에서 제목 추출
function extractTitleFromContent(content) {
  if (!content || !content.ops) return null;
  
  // 첫 번째 텍스트 블록에서 제목 추출
  for (const op of content.ops) {
    if (op.insert && typeof op.insert === 'string') {
      const text = op.insert.trim();
      if (text.length > 0) {
        // 첫 줄을 제목으로 사용 (50자 제한)
        return text.split('\n')[0].substring(0, 50);
      }
    }
  }
  return null;
}

// GitHub API를 사용하여 posts.json 파일에 새 포스트 추가
async function updatePostsJsonFile(newPost) {
  try {
    // GitHub Personal Access Token 확인
    const token = getGitHubToken();
    if (!token) {
      // 토큰이 없으면 로컬에만 저장
      console.warn('GitHub 토큰이 없습니다. 로컬에만 저장됩니다.');
      showTopMessage('GitHub 토큰이 필요합니다. 로컬에만 저장되었습니다.');
      return;
    }

    // 현재 파일 내용 가져오기
    const response = await fetch('https://api.github.com/repos/sheepycrunch/sheepycrunch.github.io/contents/src/_data/posts.json', {
      method: 'GET',
      headers: {
        'Accept': 'application/vnd.github.v3+json',
        'Authorization': `token ${token}`,
      }
    });
    
    if (!response.ok) {
      throw new Error('파일 정보 가져오기 실패: ' + response.statusText);
    }
    
    const fileData = await response.json();
    
    // 기존 포스트들 가져오기
    const existingContent = JSON.parse(atob(fileData.content));
    const existingPosts = existingContent.posts || [];
    
    // 새 포스트를 맨 앞에 추가
    const updatedPosts = [newPost, ...existingPosts];
    
    // 새 파일 내용 생성
    const newContent = JSON.stringify({ posts: updatedPosts }, null, 2);
    const encodedContent = btoa(unescape(encodeURIComponent(newContent)));
    
    // 파일 업데이트
    const updateResponse = await fetch('https://api.github.com/repos/sheepycrunch/sheepycrunch.github.io/contents/src/_data/posts.json', {
      method: 'PUT',
      headers: {
        'Accept': 'application/vnd.github.v3+json',
        'Authorization': `token ${token}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        message: `Add new post: ${newPost.title} at ${new Date().toISOString()}`,
        content: encodedContent,
        sha: fileData.sha
      })
    });
    
    if (!updateResponse.ok) {
      const errorData = await updateResponse.json();
      throw new Error('파일 업데이트 실패: ' + (errorData.message || updateResponse.statusText));
    }
    
    console.log('posts.json 파일이 성공적으로 업데이트되었습니다.');
    
  } catch (error) {
    console.error('GitHub API 업데이트 실패:', error);
    throw error;
  }
}

// GitHub Personal Access Token 가져오기
function getGitHubToken() {
  // 1. Eleventy에서 주입된 전역 데이터에서 토큰 확인
  if (window.githubToken && window.githubToken !== 'undefined' && window.githubToken !== 'null' && window.githubToken.trim() !== '') {
    console.log('Eleventy에서 주입된 GitHub 토큰을 사용합니다.');
    return window.githubToken;
  }
  
  // 2. localStorage에서 토큰 확인 (백업)
  let token = localStorage.getItem('github_token');
  
  if (!token) {
    console.warn('GitHub 토큰이 설정되지 않았습니다. AUTHOR_TOKEN 환경변수를 확인하세요.');
    return null;
  }
  
  return token;
}



// 상단 메시지 표시
function showTopMessage(message) {
  // 기존 메시지 제거
  const existingMessage = document.getElementById('top-message');
  if (existingMessage) {
    existingMessage.remove();
  }
  
  // 새 메시지 생성
  const messageDiv = document.createElement('div');
  messageDiv.id = 'top-message';
  messageDiv.textContent = message;
  
  // body 맨 앞에 추가
  document.body.insertBefore(messageDiv, document.body.firstChild);
  
  // 트랜지션을 위해 약간의 지연 후 show 클래스 추가
  setTimeout(() => {
    messageDiv.classList.add('show');
  }, 10);
  
  // 1초 후 사라지는 애니메이션 시작
  setTimeout(() => {
    if (messageDiv.parentNode) {
      messageDiv.classList.remove('show');
      
      // 트랜지션 완료 후 제거
      setTimeout(() => {
        if (messageDiv.parentNode) {
          messageDiv.remove();
        }
      }, 300);
    }
  }, 2000);
}

// 자동 저장 기능 (1분 단위)
function setupAutoSave() {
  let autoSaveInterval;
  
  // 1분마다 자동 저장 (알림 없음)
  autoSaveInterval = setInterval(async () => {
    try {
      const content = editor.getContents();
      if (content && content.ops && content.ops.length > 0) {
        saveDraft();
        // 알림 없이 조용히 저장
      }
    } catch (error) {
      console.error('자동 저장 중 오류:', error);
    }
  }, 60000); // 1분 = 60000ms
}

// 관리자 권한 체크 함수
function checkAdminPermission() {
  // AdminAuth 클래스가 정의되어 있는지 확인
  if (typeof AdminAuth !== 'undefined') {
    const adminAuth = new AdminAuth();
    return adminAuth.isAdminLoggedIn();
  }
  return false;
}

// 권한이 없으면 404 페이지로 리다이렉트
function redirectTo404() {
  window.location.href = '/404.html';
}



// Quill.js 에디터 초기화
let editor;

function initializeQuillJS() {
  // Quill.js가 로드되었는지 확인
  if (typeof Quill === 'undefined') {
    console.error('Quill.js가 로드되지 않았습니다.');
    return;
  }

  editor = new Quill('#post-content', {
    theme: 'snow',
    bounds: '#post-content',
    modules: {
      toolbar: [
        [{ 'font': ['Noto Sans CJK KR', 'Apple SD Gothic Neo', 'Malgun Gothic', '맑은 고딕', 'Arial'] }],
        [{ 'header': [1, 2, 3, false] }],
        [{ 'size': ['small', false, 'large', 'huge'] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ 'color': [] }, { 'background': [] }],
        [{ 'align': [] }, { 'list': 'ordered'}, { 'list': 'bullet' }],
        ['link', 'image']
      ]
    }
  });

  // 에디터 내용이 변경될 때마다 이벤트 발생
  editor.on('text-change', function() {
    document.getElementById('post-content').dispatchEvent(new Event('input', { bubbles: true }));
  });


  console.log('Quill.js가 성공적으로 초기화되었습니다.');
}


// 이벤트 리스너 설정
document.addEventListener('DOMContentLoaded', function() {
  // 관리자 권한 체크
  if (!checkAdminPermission()) {
    redirectTo404();
    return;
  }
  
  // Quill.js 에디터 초기화 (약간의 지연을 두어 CDN 로딩 완료 후 실행)
  setTimeout(() => {
    initializeQuillJS();
  }, 100);
  
  // 카테고리 로드 (비활성화)
  // loadCategories();
  
  // 태그 제안 설정
  setupTagSuggestions();
  
  // 이미지 업로드 설정
  setupImageUpload();
  
  // 자동 저장 설정
  setupAutoSave();
  
  
  // 버튼 이벤트 연결
  document.getElementById('save-draft-writer').addEventListener('click', saveDraft);
  document.getElementById('load-draft-writer').addEventListener('click', loadDraft);
  document.getElementById('save-post').addEventListener('click', savePost);
  
  // 페이지 로드 시 임시저장 자동 불러오기
  const draft = JSON.parse(localStorage.getItem('write-draft') || '{}');
  if (draft.content) {
    loadDraft();
  }
  
});



</script>
