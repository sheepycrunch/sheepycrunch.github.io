// AdminAuth 클래스 로드 (login.njk에서 정의된 것과 동일)
class AdminAuth {
  constructor() {
    // 환경변수에서 관리자 키 가져오기 (빌드 시점에 주입됨)
    this.adminKey = window.ADMIN_SECRET_KEY || 'DEFAULT_FALLBACK_KEY';
    this.sessionKey = 'admin_session';
    this.expiresKey = 'admin_expires';
  }
  
  verifyAdminKey(inputKey) {
    // 한글 키 지원을 위한 정규화
    const normalizedInput = this.normalizeKey(inputKey);
    const normalizedAdminKey = this.normalizeKey(this.adminKey);
    
    return normalizedInput === normalizedAdminKey;
  }
  
  // 키 정규화 함수 (한글 키 지원)
  normalizeKey(key) {
    if (!key) return '';
    
    // 공백만 제거하고 특수문자는 유지 (느낌표 등이 키의 일부일 수 있음)
    return key.toString()
      .trim()                    // 앞뒤 공백 제거
      .replace(/\s+/g, '');      // 중간 공백만 제거
  }
  
  setAdminSession() {
    const sessionToken = this.generateSessionToken();
    const expires = Date.now() + (24 * 60 * 60 * 1000);
    
    localStorage.setItem(this.sessionKey, sessionToken);
    localStorage.setItem(this.expiresKey, expires.toString());
    
    return sessionToken;
  }
  
  generateSessionToken() {
    const timestamp = Date.now();
    const random = Math.random().toString(36).substring(2);
    return btoa(`${timestamp}_${random}_ADMIN`).replace(/[+/=]/g, '');
  }
  
  isAdminLoggedIn() {
    const session = localStorage.getItem(this.sessionKey);
    const expires = localStorage.getItem(this.expiresKey);
    
    if (!session || !expires) return false;
    if (Date.now() > parseInt(expires)) {
      this.logout();
      return false;
    }
    return true;
  }
  
  logout() {
    localStorage.removeItem(this.sessionKey);
    localStorage.removeItem(this.expiresKey);
  }
}

