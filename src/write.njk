---
layout: layout.njk
title: "글 작성"
description: "글 작성"
lang: "en"
permalink: "/write.html"
---

<section id="content">
  <h2>{{ "글 작성" | t(lang) }}</h2>
  
  <div id="i18n-data" style="display: none;">{{ i18n | dump | safe }}</div>
  <!-- 다국어는 JavaScript에서 처리하도록 설정 -->
  <div class="form-group">
    <label>{{ "내용" | t(lang) }}</label>
    
    
    <div class="editor-container">
      <div id="post-content"></div>
    </div>
    <input type="file" id="image-file-input" accept="image/*" style="display: none;" />
  </div>
  
  <div class="form-group">
    <label for="post-tags">{{ "태그 (영어만)" | t(lang) }}</label>
    <input type="text" id="post-tags" class="form-input" placeholder="{{ "예: daily, thoughts, review" | t(lang) }}" />
    <div class="tag-suggestions" id="tag-suggestions"></div>
  </div>
  
  <div class="writer-actions">
    <div class="save-controls">
      <button id="save-draft-writer" class="button secondary">{{ "임시저장" | t(lang) }}</button>
      <button id="load-draft-writer" class="button secondary">{{ "임시저장 불러오기" | t(lang) }}</button>
      <button id="save-post" class="button">{{ "저장" | t(lang) }}</button>
    </div>
  </div>
</section>


<!-- Quill.js JavaScript -->
<script src="/js/quill.min.js"></script>
<link href="/css/quill.snow.css" rel="stylesheet">

<!-- Message Utils -->
<script src="/js/message-utils.js"></script>


<script>
// i18n 데이터를 JavaScript에서 사용할 수 있도록 설정
const i18nData = JSON.parse(document.getElementById('i18n-data').textContent);

// 이미지 업로드 기능
function setupImageUpload() {
  const editorContainer = document.querySelector('.editor-container');
  const fileInput = document.getElementById('image-file-input');
  
  // 드래그 앤 드롭 이벤트
  editorContainer.addEventListener('dragover', (e) => {
    e.preventDefault();
  });
  
  editorContainer.addEventListener('drop', (e) => {
    e.preventDefault();
    const files = e.dataTransfer.files;
    if (files.length > 0 && files[0].type.startsWith('image/')) {
      handleImageFile(files[0]);
    }
  });
  
  // 클릭으로 이미지 업로드 기능 (드래그앤드롭만 사용)
  // editorContainer 클릭 이벤트는 제거
  
  // 파일 선택 이벤트
  fileInput.addEventListener('change', (e) => {
    if (e.target.files.length > 0) {
      handleImageFile(e.target.files[0]);
    }
  });
}

// 이미지 파일 처리
function handleImageFile(file) {
  if (!file.type.startsWith('image/')) {
    showTopMessage('이미지 파일만 업로드할 수 있습니다.');
    return;
  }
  
  // 로컬 파일 경로 생성
  const timestamp = Date.now();
  const randomString = Math.random().toString(36).substring(2, 15);
  const extension = file.name.split('.').pop();
  const localPath = `images/uploaded/${timestamp}_${randomString}.${extension}`;
  
  // Base64로 읽어서 에디터에 삽입 (임시 저장)
  const reader = new FileReader();
  reader.onload = (e) => {
    const base64Data = e.target.result; // data:image/jpeg;base64,/9j/4AAQ...
    
    // 에디터에 Base64 이미지 삽입 (임시)
    insertImageToEditor(base64Data, localPath);
    showTopMessage('이미지가 추가되었습니다. 저장 시 파일로 변환됩니다.');
  };
  reader.readAsDataURL(file);
}

// Base64 이미지를 실제 파일로 변환
async function processBase64Images(content) {
  if (!content || !content.ops) return content;
  
  const processedOps = [];
  
  for (const op of content.ops) {
    if (op.insert && op.insert.image && op.insert.image.startsWith('data:image/')) {
      // Base64 이미지를 실제 파일로 변환
      const base64Data = op.insert.image;
      const timestamp = Date.now();
      const randomString = Math.random().toString(36).substring(2, 15);
      const extension = base64Data.split(';')[0].split('/')[1];
      const fileName = `${timestamp}_${randomString}.${extension}`;
      const localPath = `images/uploaded/${fileName}`;
      
      // Base64를 Blob으로 변환하여 다운로드
      const base64String = base64Data.split(',')[1];
      const byteCharacters = atob(base64String);
      const byteNumbers = new Array(byteCharacters.length);
      for (let i = 0; i < byteCharacters.length; i++) {
        byteNumbers[i = byteCharacters.charCodeAt(i);
      }
      const byteArray = new Uint8Array(byteNumbers);
      const blob = new Blob([byteArray], { type: `image/${extension}` });
      
      // Base64 이미지 처리 (process-images.js가 Base64를 실제 파일로 변환)
      
      // 상대 경로로 변경
      processedOps.push({
        insert: {
          image: localPath
        }
      });
    } else {
      processedOps.push(op);
    }
  }
  
  return { ops: processedOps };
}

// 에디터에 이미지 삽입
function insertImageToEditor(imagePath, localPath) {
  try {
    const range = editor.getSelection();
    const index = range ? range.index : editor.getLength();
    
    // 상대 경로로 이미지 삽입
    editor.insertEmbed(index, 'image', imagePath);
    editor.setSelection(index + 1);
    
    console.log('이미지가 에디터에 삽입되었습니다.');
  } catch (error) {
    console.error('이미지 삽입 오류:', error);
    showTopMessage('이미지 삽입 중 오류가 발생했습니다.');
  }
}

// 자동 워크플로우 실행
function executeWriteWorkflow() {
  // 로컬 서버에서만 실행
  if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
    // 자동화된 배포 워크플로우 실행
    // 사용자에게 수동 실행 안내
    showTopMessage('파일이 다운로드되었습니다. 자동으로 write-workflow.bat을 실행하도록 시도합니다.');
    
    // Node.js 서버를 통한 자동 실행
    try {
      showTopMessage('자동 워크플로우를 시작합니다...');
      
      fetch('/api/execute-workflow', {
        method: 'POST'
      })
        .then((response) => response.json())
        .then((data) => {
          if (data.success) {
            showTopMessage('Auto workflow finished successfully.');
            console.log('workflow output:', data.output);
          } else {
            showTopMessage('Auto workflow failed. Check the terminal for details.');
            console.error('workflow error:', data.error);
          }
        })
        .catch((error) => {
          console.error('workflow request failed:', error);
          showTopMessage('Could not reach the auto workflow API. Verify the Eleventy dev server.');
        });
      
    } catch (error) {
      console.error('자동 실행 오류:', error);
      showTopMessage('자동 실행에 실패했습니다. 수동으로 write-workflow.bat을 실행해주세요.');
    }
  } else {
    showTopMessage('로컬 서버에서만 실행 가능합니다. 수동으로 write-workflow.bat을 실행해주세요.');
  }
}

// 파일 복사 및 배포 실행
function executeCopyAndDeploy() {
  // 로컬 서버에서만 실행
  if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
    try {
      const shell = new ActiveXObject('WScript.Shell');
      // 1. 파일 복사 실행
      shell.Run('copy-files.bat', 1, true);
      // 2. 배포 실행
      shell.Run('deploy-local.bat', 1, false);
      showTopMessage('파일 복사 및 배포가 자동으로 시작되었습니다.');
    } catch (error) {
      console.error('실행 오류:', error);
      showTopMessage('자동 실행에 실패했습니다. 수동으로 copy-files.bat과 deploy-local.bat을 실행해주세요.');
    }
  } else {
    showTopMessage('로컬 서버에서만 자동 실행이 가능합니다. 수동으로 copy-files.bat과 deploy-local.bat을 실행해주세요.');
  }
}

// 자동 배포 스크립트 실행
function executeDeployScript() {
  // 로컬 서버에서만 실행
  if (window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1') {
    try {
      // WScript.Shell을 사용하여 bat 파일 실행
      const shell = new ActiveXObject('WScript.Shell');
      shell.Run('deploy-local.bat', 1, false);
      showTopMessage('배포가 자동으로 시작되었습니다.');
    } catch (error) {
      console.error('배포 실행 오류:', error);
      showTopMessage('자동 실행에 실패했습니다. 수동으로 deploy-local.bat을 실행해주세요.');
    }
  } else {
    showTopMessage('로컬 서버에서만 자동 배포가 가능합니다. 수동으로 deploy-local.bat을 실행해주세요.');
  }
}

// 임시저장 기능 (localStorage 사용)
async function saveDraft() {
  try {
    // editor가 초기화되었는지 확인
    if (!editor) {
      console.log('Editor not initialized yet.');
      alert('Editor not ready. Please try again in a moment.');
      return;
    }
    
    const content = editor.getContents();
    const tags = document.getElementById('post-tags').value;
    
    const draft = { 
      content, 
      tags,
      savedAt: new Date().toISOString() 
    };
    
    localStorage.setItem('write-draft', JSON.stringify(draft));
    showTopMessage('Draft saved.');
  } catch (error) {
    console.error('Error saving:', error);
    showTopMessage('An error occurred while saving.');
  }
}

// 임시저장 불러오기
async function loadDraft() {
  const draft = JSON.parse(localStorage.getItem('write-draft') || '{}');
  
  if (draft.content) {
    try {
      // editor가 초기화되었는지 확인
      if (!editor) {
        console.log('에디터가 아직 초기화되지 않았습니다. 1초 후 다시 시도합니다.');
        setTimeout(loadDraft, 1000);
        return;
      }
      
      editor.setContents(draft.content);
      document.getElementById('post-tags').value = draft.tags || '';
      
      // 성공 메시지 표시
      showTopMessage(i18nData?.write?.messages?.draftLoaded || '임시저장된 내용을 불러왔습니다.');
    } catch (error) {
    console.error('Error loading:', error);
    showTopMessage('An error occurred while loading.');
    }
  } else {
    showTopMessage(i18nData?.write?.messages?.noDraft || '임시저장된 내용이 없습니다.');
  }
}

// 태그 제안 기능 (기존 태그에서 추출)
function setupTagSuggestions() {
  const tagInput = document.getElementById('post-tags');
  const suggestions = document.getElementById('tag-suggestions');
  
  // 기존 포스트에서 모든 태그 추출
  function getAllExistingTags() {
    const posts = JSON.parse(localStorage.getItem('hamster_posts') || '[]');
    const allTags = new Set();
    
    console.log('All posts data:', posts);
    
    posts.forEach(post => {
      console.log('Post tags:', post.tags, 'type:', typeof post.tags);
      if (post.tags) {
        if (Array.isArray(post.tags)) {
          // 배열인 경우
          post.tags.forEach(tag => {
            if (tag && tag.trim()) {
              allTags.add(tag.trim());
            }
          });
        } else if (typeof post.tags === 'string') {
          // 문자열인 경우 (쉼표로 분리)
          const tags = post.tags.split(',').map(tag => tag.trim()).filter(tag => tag);
          tags.forEach(tag => allTags.add(tag));
        }
      }
    });
    
    console.log('Extracted tags:', Array.from(allTags));
    return Array.from(allTags);
  }
  
  // 기존 태그 표시
  function showExistingTags() {
    const existingTags = getAllExistingTags();
    if (existingTags.length > 0) {
      suggestions.innerHTML = `
        <div class="existing-tags-list">
          ${existingTags.map(tag => 
            `<span class="tag-button" onclick="addTag('${tag}')">${tag}</span>`
          ).join('')}
        </div>
      `;
      suggestions.style.display = 'block';
    } else {
      suggestions.innerHTML = `
        <div class="existing-tags-title">${i18nData?.write?.messages?.existingTags || '기존 태그'}</div>
        <div class="no-results">${i18nData?.write?.messages?.noTagsAvailable || '사용 가능한 태그가 없습니다.'}</div>
      `;
      suggestions.style.display = 'block';
    }
  }
  
  // 초기 로드 시 기존 태그 표시 (검색어 없이)
  showExistingTags();
  
  tagInput.addEventListener('input', () => {
    const value = tagInput.value.toLowerCase();
    const existingTags = getAllExistingTags();
    const currentTags = tagInput.value.split(',').map(t => t.trim()).filter(t => t);
    
    if (value.length > 0) {
      const filteredTags = existingTags.filter(tag => 
        tag.toLowerCase().includes(value) && !currentTags.includes(tag)
      );
      
      if (filteredTags.length > 0) {
        suggestions.innerHTML = `
          <div class="filtered-tags-title">${i18nData?.write?.messages?.searchResults || '검색 결과:'}</div>
          <div class="filtered-tags-list">
            ${filteredTags.slice(0, 10).map(tag => 
              `<span class="tag-button" onclick="addTag('${tag}')">${tag}</span>`
            ).join('')}
          </div>
        `;
        suggestions.style.display = 'block';
      } else {
        suggestions.innerHTML = `<div class="no-results">${i18nData?.write?.messages?.noResults || '검색 결과가 없습니다.'}</div>`;
        suggestions.style.display = 'block';
      }
    } else {
      showExistingTags();
    }
  });
  
  // 포커스 시 기존 태그 표시
  tagInput.addEventListener('focus', () => {
    showExistingTags();
  });
}

function addTag(tag) {
  const tagInput = document.getElementById('post-tags');
  const currentTags = tagInput.value.split(',').map(t => t.trim()).filter(t => t);
  
  if (!currentTags.includes(tag)) {
    currentTags.push(tag);
    tagInput.value = currentTags.join(', ');
  }
  
  document.getElementById('tag-suggestions').style.display = 'none';
  tagInput.focus();
}


async function savePost() {
  try {
    // editor가 초기화되었는지 확인
    if (!editor) {
      console.log('Editor not initialized yet.');
      alert('Editor not ready. Please try again in a moment.');
      return;
    }
    
    const content = editor.getContents();
    const tags = document.getElementById('post-tags').value.split(',').map(tag => tag.trim()).filter(tag => tag);
    
    if (!content || !content.ops || content.ops.length === 0) {
      showTopMessage(i18nData?.write?.messages?.noContent || '내용을 입력해주세요.');
      return;
    }
    
    // Base64 이미지를 실제 파일로 변환
    const processedContent = await processBase64Images(content);
    
    // 기존 포스트들 가져오기 (현재는 빈 배열)
    const existingPosts = [];
    
    // 새 포스트 생성
    const newPost = {
      id: Date.now(),
      date: new Date().toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' }).replace(/\./g, '.').replace(/\s/g, ''),
      description: processedContent,
      tags: tags,
      createdAt: new Date().toISOString(),
    };
    
    // 새 포스트를 기존 포스트 목록에 추가
    existingPosts.push(newPost);
    
    // localStorage 사용하지 않음 (posts.json 파일로만 관리)
    
    // posts.json 파일 생성
    const postsData = { posts: existingPosts };
    const postsJson = JSON.stringify(postsData, null, 2);
    
    // posts.json 파일 다운로드 (수동으로 src/ 폴더에 저장)
    try {
      // Blob을 사용하여 파일 다운로드
      const blob = new Blob([postsJson], { type: 'application/json' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'posts.json';
      a.style.display = 'none';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
      
      showTopMessage('파일이 다운로드되었습니다. 자동으로 복사하여 배포합니다...');
      
      // 자동 워크플로우 실행
      setTimeout(() => {
        executeWriteWorkflow();
      }, 1000);
      
    } catch (error) {
      console.error('파일 저장 오류:', error);
      showTopMessage('파일 저장 중 오류가 발생했습니다. 수동으로 deploy-local.bat을 실행해주세요.');
    }
    
    // 에디터 초기화
    editor.setContents([]);
    document.getElementById('post-tags').value = '';
    
    console.log('New post saved:', newPost);
    showTopMessage(i18nData?.write?.messages?.saveSuccess || '포스트가 저장되었습니다.');
    
    // 통계 업데이트 이벤트 발생
    if (window.statsManager) {
      window.statsManager.updatePostCount();
    }
    window.dispatchEvent(new CustomEvent('postUpdated'));
    
    
  } catch (error) {
    console.error('Error saving:', error);
    showTopMessage('An error occurred while saving: ' + error.message);
  }
}

// 자동 저장 기능 (1분마다)
function setupAutoSave() {
  let autoSaveInterval;
  
  // 1분마다 자동 저장 (저장 없음)
  autoSaveInterval = setInterval(async () => {
    try {
      const content = editor.getContents();
      if (content && content.ops && content.ops.length > 0) {
        saveDraft();
        // 저장 없이 임시저장만
      }
    } catch (error) {
      console.error('Auto-save error:', error);
    }
  }, 60000); // 1분 = 60000ms
}




// Quill.js 에디터 초기화
let editor;

function initializeQuillJS() {
  // Quill.js가 로드되었는지 확인
  if (typeof Quill === 'undefined') {
    console.error('Quill.js not loaded.');
    return;
  }

  editor = new Quill('#post-content', {
    theme: 'snow',
    bounds: '#post-content',
    modules: {
      toolbar: [
        [{ 'font': ['Noto Sans CJK KR', 'Apple SD Gothic Neo', 'Malgun Gothic', '맑은 고딕', 'Arial'] }],
        [{ 'header': [1, 2, 3, false] }],
        [{ 'size': ['small', false, 'large', 'huge'] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ 'color': [] }, { 'background': [] }],
        [{ 'align': [] }, { 'list': 'ordered'}, { 'list': 'bullet' }],
        ['link', 'image']
      ]
    }
  });

  // 에디터 내용이 변경될 때마다 이벤트 발생
  editor.on('text-change', function() {
    document.getElementById('post-content').dispatchEvent(new Event('input', { bubbles: true }));
  });


  console.log('Quill.js successfully initialized.');
}


// 이벤트 리스너 설정
document.addEventListener('DOMContentLoaded', function() {
  
  // Quill.js 에디터 초기화 (약간의 지연을 두어 CDN 로딩 완료 후 실행)
  setTimeout(() => {
    initializeQuillJS();
  }, 100);
  
  // 카테고리 로드 (사용하지 않음)
  // loadCategories();
  
  // 태그 제안 설정
  setupTagSuggestions();
  
  // 이미지 업로드 설정
  setupImageUpload();
  
  // 자동 저장 설정
  setupAutoSave();
  
  
  // 버튼 이벤트 연결
  document.getElementById('save-draft-writer').addEventListener('click', saveDraft);
  document.getElementById('load-draft-writer').addEventListener('click', loadDraft);
  document.getElementById('save-post').addEventListener('click', savePost);
  
  // 페이지 로드 시 임시저장 자동 불러오기
  const draft = JSON.parse(localStorage.getItem('write-draft') || '{}');
  if (draft.content) {
    loadDraft();
  }
  
});



</script>