<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; frame-src 'self' https://www.youtube.com https://www.youtube-nocookie.com; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: blob: https:; connect-src 'self' data: blob: https://neocities.org; font-src 'self' data:;">
  <title>{{ title }} - {{ site.title }}</title>
  <link rel="icon" href="neocities.png">
  <link href="/css/reset.css" rel="stylesheet" type="text/css" media="all">
  <link href="/style.css" rel="stylesheet" type="text/css" media="all">
  <link href="/css/contenttools-admin.css" rel="stylesheet" type="text/css" media="all">
  
  <!-- Environment configuration variables -->
  <script>
    window.USERNAME = '{{ siteName }}';
    window.NEOCITIES_URL = '{{ neocitiesUrl }}';
    window.NEKOWEB_URL = '{{ nekowebUrl }}';
    window.NEOCITIES_API_KEY = '{{ neocitiesApiToken }}';
  </script>
  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}
  {% if refresh %}
  <meta http-equiv="refresh" content="{{ refresh }}">
  {% endif %}
</head>
<body>
  <article data-name="main-article">
    <header class="bordered">
      {% if page.hideHeader %}
      <!-- Hide header -->
      {% elif page.url == '/' or page.url == '/index.html' %}
      <h1>{{ site.title }}</h1>
      {% else %}
      <h2 class="page-title">
        <a href="/" class="title-link">{{ site.title }}</a>
        <span>/</span>
        <span class="current-page">{{ page.url | replace("/", "") | replace(".html", "") | replace("index", "") or "home" }}</span>
      </h2>
      {% endif %}
    </header>
    
    {{ content | safe }}
    
    {% if page.showNavigation %}
    <nav class="bubble-nav">
      {% for nav in site.navigation %}
      <a href="{{ nav.url }}" class="bubble">{{ nav.name }}</a>
      {% endfor %}
    </nav>
    {% endif %}
    
    
  </article>
  
  {% if page.scripts %}
  {% for script in page.scripts %}
  <script src="{{ script }}"></script>
  {% endfor %}
  {% endif %}
  
  {% if page.customScripts %}
  {% for script in page.customScripts %}
  <script>{{ script | safe }}</script>
  {% endfor %}
  {% endif %}
  
  <!-- ContentTools 로컬 파일 -->
  <link rel="stylesheet" href="/css/contenttools.min.css">
  <script src="/js/contenttools.min.js"></script>
  
  <!-- Message Utils -->
  <script src="/js/message-utils.js"></script>
  
  <!-- Global ContentTools -->
  <script src="/js/global-contenttools.js"></script>
  
  <script>
  // Common tag search function
  function searchByTag(tag) {
    // Navigate to search page and search with the tag
    window.location.href = '/search/?tag=' + encodeURIComponent(tag);
  }
  
  // ContentTools debugging function
  window.debugContentTools = function() {
    console.log('=== ContentTools Debug Information ===');
    console.log('ContentTools loaded:', typeof ContentTools !== 'undefined');
    console.log('ContentEdit loaded:', typeof ContentEdit !== 'undefined');
    console.log('Editable elements:', document.querySelectorAll('*[data-editable]').length);
    console.log('ContentToolsManager:', typeof window.ContentToolsManager);
    if (window.ContentToolsManager) {
      console.log('Editor initialized:', window.ContentToolsManager.isInitialized());
    }
    console.log('================================');
  };
  
  // Auto debugging after page load
  document.addEventListener('DOMContentLoaded', function() {
    setTimeout(() => {
      console.log('Page load complete, checking ContentTools status...');
      debugContentTools();
    }, 1000);
  });
  </script>
</body>
</html>