<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - ✨ Kawaii Anime Paradise ✨</title>
  <link href="/style.css" rel="stylesheet" type="text/css" media="all">
  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}
  {% if refresh %}
  <meta http-equiv="refresh" content="{{ refresh }}">
  {% endif %}
</head>
<body>
  <div id="wrapper">
    <div class="main-layout">
      <div class="sidebar scanline">
        <h1 class="logo-text glitter">🌸 Kawaii Anime Paradise 🌸</h1>
        <p class="tagline blink">Welcome to my magical anime world! ✨</p>
        <nav class="nav">
          <ul>
            <li><a href="/">🏠 Home Sweet Home 🏠</a></li>
            <li><a href="/gallery">🎨 Kawaii Gallery 🎨</a></li>
            <li><a href="/about">💖 About Me 💖</a></li>
            <li><a href="/contact">📞 Contact ✨</a></li>
            <li><a href="/anime">🎌 Anime Corner 🎌</a></li>
            <li><a href="/manga">📚 Manga Library 📚</a></li>
          </ul>
        </nav>
        <div class="box accent" style="margin-top: 20px;">
          <h3 class="anime-heart">💕 Visitor Counter 💕</h3>
          <p class="anime-star">You are visitor #999,999! ✨</p>
          <p class="anime-sparkle">Thank you for visiting! 🌸</p>
        </div>
      </div>
      <div class="main-content scanline">
        {{ content | safe }}
      </div>
    </div>
  </div>
  
  {% if scripts %}
  {% for script in scripts %}
  <script>{{ script | safe }}</script>
  {% endfor %}
  {% endif %}
</body>
</html>
