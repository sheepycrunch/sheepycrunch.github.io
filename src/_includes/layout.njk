<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; img-src 'self' data: blob: https:; connect-src 'self' data: blob: https://neocities.org; font-src 'self' data:;">
  <title>{{ title }} - {{ site.title }}</title>
  <link rel="icon" href="neocities.png">
  <link href="/css/reset.css" rel="stylesheet" type="text/css" media="all">
  <link href="/style.css" rel="stylesheet" type="text/css" media="all">
  <link href="/css/contenttools-admin.css" rel="stylesheet" type="text/css" media="all">
  
  <!-- 환경 설정 변수들 -->
  <script>
    window.USERNAME = '{{ siteName }}';
    window.NEOCITIES_URL = '{{ neocitiesUrl }}';
    window.NEKOWEB_URL = '{{ nekowebUrl }}';
    window.NEOCITIES_API_KEY = '{{ neocitiesApiToken }}';
  </script>
  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}
  {% if refresh %}
  <meta http-equiv="refresh" content="{{ refresh }}">
  {% endif %}
</head>
<body>
  <article data-name="main-article">
    <header class="bordered">
      {% if page.hideHeader %}
      <!-- 헤더 숨김 -->
      {% elif page.url == '/' or page.url == '/index.html' %}
      <h1>{{ site.title }}</h1>
      {% else %}
      <h2 class="page-title">
        <a href="/" class="title-link">{{ site.title }}</a>
        <span>/</span>
        <span class="current-page">{{ page.url | replace("/", "") | replace(".html", "") | replace("index", "") or "home" }}</span>
      </h2>
      {% endif %}
    </header>
    
    {{ content | safe }}
    
    {% if page.showNavigation %}
    <nav class="bubble-nav">
      {% for nav in site.navigation %}
      <a href="{{ nav.url }}" class="bubble">{{ nav.name }}</a>
      {% endfor %}
    </nav>
    {% endif %}
    
    <!-- ContentTools 다운로드 버튼 -->
    <div class="contenttools-actions">
      <button id="download-content" class="bubble download-content-button">
        Download Latest Content
      </button>
    </div>
    
  </article>
  
  {% if page.scripts %}
  {% for script in page.scripts %}
  <script src="{{ script }}"></script>
  {% endfor %}
  {% endif %}
  
  {% if page.customScripts %}
  {% for script in page.customScripts %}
  <script>{{ script | safe }}</script>
  {% endfor %}
  {% endif %}
  
  <!-- ContentTools 로컬 파일 -->
  <link rel="stylesheet" href="/css/contenttools.min.css">
  <script src="/js/contenttools.min.js"></script>
  
  <!-- Message Utils -->
  <script src="/js/message-utils.js"></script>
  
  <!-- Global ContentTools -->
  <script src="/js/global-contenttools.js"></script>
  
  <script>
  // 공통 태그 검색 함수
  function searchByTag(tag) {
    // 검색 페이지로 이동하여 해당 태그로 검색
    window.location.href = '/search/?tag=' + encodeURIComponent(tag);
  }
  
  // ContentTools 디버깅 함수
  window.debugContentTools = function() {
    console.log('=== ContentTools 디버깅 정보 ===');
    console.log('ContentTools 로드됨:', typeof ContentTools !== 'undefined');
    console.log('ContentEdit 로드됨:', typeof ContentEdit !== 'undefined');
    console.log('편집 가능한 요소들:', document.querySelectorAll('*[data-editable]').length);
    console.log('ContentToolsManager:', typeof window.ContentToolsManager);
    if (window.ContentToolsManager) {
      console.log('에디터 초기화됨:', window.ContentToolsManager.isInitialized());
    }
    console.log('================================');
  };
  
  // 페이지 로드 후 자동 디버깅
  document.addEventListener('DOMContentLoaded', function() {
    setTimeout(() => {
      console.log('페이지 로드 완료, ContentTools 상태 확인...');
      debugContentTools();
    }, 1000);
  });
  </script>
</body>
</html>