<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - DIY Hamster Dungeon</title>
  <link rel="stylesheet" href="/style.css" type="text/css" media="all">
  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}
  {% if refresh %}
  <meta http-equiv="refresh" content="{{ refresh }}">
  {% endif %}
</head>
<body class="y2k-body">
  <div class="page-shell">
    <aside class="side-strip">
      <img src="/images/1998/strip-01.jpg" alt="" class="strip-img">
      <img src="/images/1998/strip-02.jpg" alt="" class="strip-img">
      <img src="/images/1998/strip-03.jpg" alt="" class="strip-img">
    </aside>

    <main class="main-pane">
      <header class="cloud-header">
        <h1>DIY Hamster Dungeon</h1>
        <h2>Welcome to My Creative Space</h2>
        <p class="greeting">WELCOME! 안녕하세요! 환영합니다!</p>
      </header>

      <section class="content-paper">
        {{ content | safe }}
      </section>

      <nav class="bubble-nav">
        <a href="/" class="bubble">Home</a>
        <a href="/gallery" class="bubble">Gallery</a>
        <a href="/about" class="bubble">About</a>
        <a href="/contact" class="bubble">Contact</a>
        <a href="/links" class="bubble">Links</a>
        <a href="/projects" class="bubble">Projects</a>
      </nav>
    </main>
  </div>

  {% if scripts %}
  {% for script in scripts %}
  <script>{{ script | safe }}</script>
  {% endfor %}
  {% endif %}
</body>
</html>