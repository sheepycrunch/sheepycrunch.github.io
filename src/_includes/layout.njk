<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} ? DIY Hamster Dungeon</title>
  <link rel="stylesheet" href="/style.css" type="text/css" media="all">
  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}
  {% if refresh %}
  <meta http-equiv="refresh" content="{{ refresh }}">
  {% endif %}
</head>
<body class="y2k-body">
  <div class="page-shell">
    <aside class="side-strip">
      <img src="/images/1998/strip-01.jpg" alt="" class="strip-img">
      <img src="/images/1998/strip-02.jpg" alt="" class="strip-img">
      <img src="/images/1998/strip-03.jpg" alt="" class="strip-img">
    </aside>

    <main class="main-pane">
      <header class="cloud-header">
        <h1>It's a Wonderful World</h1>
        <h2>The Wonderful World of Sailor Moon</h2>
        <p class="greeting">WELCOME! BIENVENU! OLA! BIENVENUTI!</p>
      </header>

      <section class="content-paper">
        {{ content | safe }}
      </section>

      <nav class="bubble-nav">
        <a href="/" class="bubble">Home</a>
        <a href="/temples" class="bubble">The Sailor Temples</a>
        <a href="/adventure" class="bubble">The Wonderful Adventure</a>
        <a href="/cupids-arrow" class="bubble">Cupid's Arrow</a>
        <a href="/links" class="bubble">Wonderful Links</a>
        <a href="/contact" class="bubble">Email</a>
      </nav>
    </main>
  </div>

  {% if scripts %}
  {% for script in scripts %}
  <script>{{ script | safe }}</script>
  {% endfor %}
  {% endif %}
</body>
</html>