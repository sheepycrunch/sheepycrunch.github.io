<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - DIY Hamster Dungeon</title>
  <link href="/style.css" rel="stylesheet" type="text/css" media="all">
  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}
  {% if refresh %}
  <meta http-equiv="refresh" content="{{ refresh }}">
  {% endif %}
</head>
<body>
  <div id="wrapper">
    <div class="main-layout">
      <div class="sidebar scanline">
        <h1 class="logo-text glitter">DIY Hamster Dungeon</h1>
        <p class="tagline blink">Welcome to my hamster lair on the web!</p>
        <nav class="nav">
          <ul>
            <li><a href="/">★ Home ★</a></li>
            <li><a href="/gallery">☆ Gallery ☆</a></li>
            <li><a href="/about">✿ About ✿</a></li>
            <li><a href="/contact">☎ Contact ☎</a></li>
          </ul>
        </nav>
      </div>
      <div class="main-content scanline">
        {{ content | safe }}
      </div>
    </div>
  </div>
  
  {% if scripts %}
  {% for script in scripts %}
  <script>{{ script | safe }}</script>
  {% endfor %}
  {% endif %}
</body>
</html>
