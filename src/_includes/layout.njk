<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - 100%health</title>
  <link href="/style.css" rel="stylesheet" type="text/css" media="all">
  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}
  {% if refresh %}
  <meta http-equiv="refresh" content="{{ refresh }}">
  {% endif %}
</head>
<body>
  <div id="wrapper">
    <div id="flexrayout">
      <div id="item1">
        <h1 id="sitetitle" title="site title">100%health</h1>
        <br>
      </div>
      <div id="item2">
        {{ content | safe }}
      </div>
    </div>
  </div>
  
  {% if scripts %}
  {% for script in scripts %}
  <script>{{ script | safe }}</script>
  {% endfor %}
  {% endif %}
</body>
</html>
