<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - {{ site.title }}</title>
  <link rel="icon" href="neocities.png">
  <link href="/css/reset.css" rel="stylesheet" type="text/css" media="all">
  <link href="/style.css" rel="stylesheet" type="text/css" media="all">
  
  <!-- 전역 설정 변수들 -->
  <script>
    window.SITE_NAME = '{{ siteName }}';
    window.NEOCITIES_URL = '{{ neocitiesUrl }}';
    window.NEKOWEB_URL = '{{ nekowebUrl }}';
  </script>
  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}
  {% if refresh %}
  <meta http-equiv="refresh" content="{{ refresh }}">
  {% endif %}
</head>
<body>
  <article>
    <header class="bordered">
      {% if page.hideHeader %}
      <!-- 헤더 숨김 -->
      {% elif page.url == '/' or page.url == '/index.html' %}
      <h1>{{ site.title }}</h1>
      {% else %}
      <h2 class="page-title">
        <a href="/" class="title-link">{{ site.title }}</a>
        <span>/</span>
        <span class="current-page">{{ page.url | replace("/", "") | replace(".html", "") | replace("index", "") or "home" }}</span>
      </h2>
      {% endif %}
      {% if page.lang %}
      <div class="language-switcher">
        {% for lang in languageLinks(page.lang) %}
        <a href="{{ lang.url }}" class="lang-link {% if lang.current %}current{% endif %}">
          {{ lang.name }}
        </a>
        {% endfor %}
      </div>
      {% endif %}
    </header>
    
    {{ content | safe }}
    
    {% if page.showNavigation %}
    <nav class="bubble-nav">
      {% for nav in site.navigation %}
      <a href="{{ nav.url }}" class="bubble">{{ nav.name }}</a>
      {% endfor %}
    </nav>
    {% endif %}
    
  </article>
  
  {% if page.scripts %}
  {% for script in page.scripts %}
  <script src="{{ script }}"></script>
  {% endfor %}
  {% endif %}
  
  {% if page.customScripts %}
  {% for script in page.customScripts %}
  <script>{{ script | safe }}</script>
  {% endfor %}
  {% endif %}
  
  <script>
  // 공통 태그 검색 함수
  function searchByTag(tag) {
    // 검색 페이지로 이동하여 해당 태그로 검색
    window.location.href = '/search/?tag=' + encodeURIComponent(tag);
  }
  </script>
</body>
</html>