<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  {% if description %}
  <meta name="description" content="{{ description }}">
  {% endif %}
  <style>
    :root {
      --color-main: #fff;
      --color-sub: #000;
      --color-secondary: #888;
      --color-tertiary: #ccc;
      --color-accent: #00f;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    html {
      width: 100%;
      height: 100%;
      overflow: hidden;
    }

    body {
      width: 100%;
      height: 100%;
      margin: 0;
      padding: 0;
      font-family: "Helvetica Neue", Helvetica, Arial, system-ui, sans-serif;
      font-size: 13px;
      line-height: 1.5;
      letter-spacing: -0.02em;
      color: var(--color-sub);
      background: var(--color-main);
      overflow: hidden;
    }

    #wrapper {
      width: 100%;
      height: 100%;
      overflow: hidden auto;
      scrollbar-width: thin;
      display: flex;
      flex-direction: column;
      border-left: 40px solid var(--color-sub);
    }

    a {
      color: var(--color-sub);
      text-decoration: underline;
      transition: 0.1s ease;
    }
    a:hover {
      color: var(--color-main);
      background-color: var(--color-sub);
    }

    ::selection {
      color: var(--color-main);
      background-color: var(--color-accent);
    }

    /* header */
    .site-header {
      padding: 12px 16px 8px;
      border-bottom: 2px solid var(--color-sub);
    }
    .site-title {
      font-size: 1.8rem;
      font-weight: normal;
      line-height: 1;
      letter-spacing: -0.04em;
    }
    .site-nav {
      margin-top: 6px;
      font-size: 11px;
    }
    .site-nav a {
      margin-right: 8px;
    }

    /* main content */
    .content {
      flex: 1;
      padding: 16px 16px 40px;
      max-width: 640px;
    }

    .page-title {
      font-size: 1rem;
      font-weight: normal;
      display: inline-block;
      color: var(--color-main);
      background-color: var(--color-sub);
      padding: 1px 6px;
      margin-bottom: 12px;
    }

    .last-updated {
      font-size: 11px;
      color: var(--color-secondary);
      margin-bottom: 16px;
    }

    h2 {
      font-size: 1em;
      font-weight: normal;
      display: inline-block;
      color: var(--color-main);
      background-color: var(--color-secondary);
      padding: 0 4px;
      margin: 16px 0 6px;
      line-height: 1.4;
    }

    h3 {
      font-size: 1em;
      font-weight: normal;
      margin: 12px 0 4px;
    }
    h3::before {
      content: "> ";
    }

    p {
      margin: 4px 0 8px;
      line-height: 1.6;
    }

    ul, ol {
      margin: 4px 0 8px 16px;
      line-height: 1.6;
    }

    li {
      margin-bottom: 2px;
    }

    section {
      padding-bottom: 10px;
      margin-bottom: 10px;
      border-bottom: dotted 2px var(--color-sub);
    }
    section:last-of-type {
      border-bottom: none;
    }

    /* contact info */
    .contact-info {
      background: #f8f8f8;
      border: 1px solid var(--color-tertiary);
      padding: 8px 12px;
      margin: 8px 0;
      font-size: 12px;
    }

    /* footer */
    .site-footer {
      padding: 8px 16px;
      border-top: 2px solid var(--color-sub);
      font-size: 11px;
      color: var(--color-secondary);
    }

    /* responsive */
    @media screen and (max-width: 576px) {
      #wrapper {
        border-left: 20px solid var(--color-sub);
      }
      .content {
        padding: 12px 12px 32px;
      }
    }

    @media screen and (max-width: 320px) {
      #wrapper {
        border-left: none;
      }
    }
  </style>
</head>
<body>
  <div id="wrapper">
    <header class="site-header">
      <div class="site-title">sheepycrunch</div>
      <nav class="site-nav">
        <a href="/">home</a>
        <a href="/app.html">app</a>
        <a href="/privacy.html">privacy</a>
        <a href="/terms.html">terms</a>
      </nav>
    </header>

    <main class="content">
      <div class="page-title">{{ title }}</div>
      {% if updated %}
      <div class="last-updated">last updated: {{ updated }}</div>
      {% endif %}

      {{ content | safe }}
    </main>

    <footer class="site-footer">
      &copy; 2026 sheepycrunch
    </footer>
  </div>
</body>
</html>
