---
layout: layout.njk
title: "DIY Hamster Dungeon"
description: "DIY Hamster Dungeon - 個人ブログ"
showNavigation: true
css: "/index.css"
lang: "jp"
---

<!-- 아이콘 쇼케이스 섹션 -->
<section id="icon-showcase">
  <ol>
    <li><img src="{{ '/images/icons/icon1.png' | neocitiesImage }}" alt="icon" onerror="this.style.display='none'"></li>
    <li class="hidden"><img src="{{ '/images/icons/icon2.png' | neocitiesImage }}" alt="icon" onerror="this.style.display='none'"></li>
    <li class="hidden"><img src="{{ '/images/icons/icon3.png' | neocitiesImage }}" alt="icon" onerror="this.style.display='none'"></li>
    <li class="hidden"><img src="{{ '/images/icons/icon4.png' | neocitiesImage }}" alt="icon" onerror="this.style.display='none'"></li>
    <li class="hidden"><img src="{{ '/images/icons/icon5.png' | neocitiesImage }}" alt="icon" onerror="this.style.display='none'"></li>
  </ol>
  <img id="misuzu-button" class="clickable" src="{{ '/images/button.png' | neocitiesImage }}" alt="click to change icon" onerror="this.style.display='none'">
</section>

<!-- 자기소개 섹션 -->
<section>
  <h2>{{ i18n_jp.sections.selfIntroduction }}</h2>
  <dl id="name-display">
    <dt>{{ i18n_jp.author.name }}</dt>
    <dd>{{ site.author.name }}</dd>
  </dl>
  <p>{{ i18n_jp.author.introduction }}</p>
  <p>{{ i18n_jp.author.hobbies }}: {{ i18n_jp.hobbies | join(', ') }}</p>
  <p>{{ i18n_jp.author.currentProject }}</p>
</section>

<!-- 사이트 소개 섹션 -->
<section>
  <h2>{{ i18n_jp.sections.aboutSite }}</h2>
  <p>{{ i18n_jp.aboutSite.text1 }}</p>
  <p>{{ i18n_jp.aboutSite.text2 }}</p>
</section>

<!-- SNS 링크 섹션 -->
<section>
  <h2>{{ i18n_jp.sections.snsLinks }}</h2>
  <ul class="horizontal-layout">
    {% if site.social.twitter %}
    <li>
      <a href="{{ site.social.twitter }}" target="_blank">
        <img src="/images/social/twitter.png" alt="Twitter" class="link-icon clickable" onerror="this.style.display='none'">
      </a>
    </li>
    {% endif %}
    {% if site.social.github %}
    <li>
      <a href="{{ site.social.github }}" target="_blank">
        <img src="/images/social/github.png" alt="GitHub" class="link-icon clickable" onerror="this.style.display='none'">
      </a>
    </li>
    {% endif %}
    {% if site.social.pixiv %}
    <li>
      <a href="{{ site.social.pixiv }}" target="_blank">
        <img src="/images/social/pixiv.png" alt="Pixiv" class="link-icon clickable" onerror="this.style.display='none'">
      </a>
    </li>
    {% endif %}
  </ul>
</section>

<!-- 콘텐츠 섹션 -->
<section>
  <h2>{{ i18n_jp.sections.content }}</h2>
  <ul class="horizontal-layout">
    {% for nav in i18n_jp.navigation %}
    <li>
      <a href="{{ nav.url | localizedUrl('jp') }}">
        <div class="clickable button-like-decoration">
          <p>{{ nav.name }}</p>
        </div>
      </a>
    </li>
    {% endfor %}
  </ul>
</section>

<!-- 통계 정보 섹션 -->
<section>
  <h2>{{ i18n_jp.sections.siteInfo }}</h2>
  <div class="info-stats">
    <div class="stat-item">
      <span class="stat-label">{{ i18n_jp.stats.posts }}:</span>
      <span class="stat-value">{{ site.stats.posts }}</span>
    </div>
    <div class="stat-item">
      <span class="stat-label">{{ i18n_jp.stats.visitors }}:</span>
      <span class="stat-value">{{ site.stats.visitors }}</span>
    </div>
    <div class="stat-item">
      <span class="stat-label">{{ i18n_jp.stats.lastUpdate }}:</span>
      <span class="stat-value">{{ site.stats.lastUpdate }}</span>
    </div>
  </div>
</section>

<!-- 최신 업데이트 섹션 -->
<section>
  <h2>{{ i18n_jp.sections.latestUpdates }}</h2>
    <div class="update-list">
      {% for update in i18n_jp.updates %}
      <div class="update-item">
        <span class="update-date">{{ update.date }}</span>
        <span class="update-text">{{ update.text }}</span>
      </div>
      {% endfor %}
    </div>
</section>

<!-- 기능 소개 섹션 -->
<section>
  <h2>{{ i18n_jp.sections.mainFeatures }}</h2>
    <div class="feature-list">
    {% for feature in i18n_jp.features %}
      <div class="feature-item">
      <span class="feature-icon">{{ feature.icon }}</span>
      <span class="feature-title">{{ feature.title }}</span>
      <span class="feature-desc">{{ feature.description }}</span>
    </div>
    {% endfor %}
  </div>
</section>

<!-- 방문자 메시지 -->
<section class="visitor-message">
  <h3>{{ i18n_jp.visitorMessage.title }}</h3>
  <p>{{ i18n_jp.visitorMessage.text }}</p>
  <div class="message-actions">
    <a href="/contact" class="button">{{ i18n_jp.visitorMessage.actions.sendMessage }}</a>
    <a href="/gallery" class="button secondary">{{ i18n_jp.visitorMessage.actions.viewGallery }}</a>
  </div>
</section>

<!-- JavaScript 파일들 -->
<script src="/js/icon-changer.js"></script>
<script src="/js/stats-manager.js"></script>
<script src="/js/admin-panel.js"></script>
