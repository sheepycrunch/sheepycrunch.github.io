---
layout: layout.njk
title: "글"
description: "텍스트 포스트들을 확인하세요."
lang: "kr"
permalink: "/txt.html"
---

<section id="content">
  <h2>{{ i18n.txt.title | t(lang) }}</h2>
  
  <div class="post-list">
    {% for item in posts.posts %}
      {% if item.category == "txt" %}
      <div class="post-item">
        {% if item.image %}
        <div class="post-image">
          <img src="{{ item.image }}" alt="{{ item.description }}" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
          <div class="image-placeholder" {% if item.image %}style="display: none;"{% endif %}>
          </div>
        </div>
        {% endif %}
        <div class="post-content">
          <div class="post-text">{{ item.description | safe }}</div>
          <div class="post-footer">
            <div class="post-meta">{{ item.date }}</div>
            {% if item.tags %}
            <div class="post-tags">
              {% for tag in item.tags %}
              <button class="tag-button" onclick="searchByTag('{{ tag }}')">#{{ tag }}</button>
              {% endfor %}
            </div>
            {% endif %}
          </div>
        </div>
      </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

