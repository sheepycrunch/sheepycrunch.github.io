---
layout: layout.njk
title: "글"
description: "텍스트 포스트들을 확인하세요."
lang: "en"
permalink: "/txt.html"
---

<section id="content">
  <section data-editable data-name="txt-header">
    <h2>Posts</h2>
  </section>
  
  <section data-editable data-name="txt-content">
    <div class="post-list" id="post-list">
      <!-- Static posts (build time) -->
      {% for item in posts.posts %}
        <div class="post-item">
          {% if item.image %}
          <div class="post-image">
            {{ item.image | dualImage | safe }}
            <div class="image-placeholder" {% if item.image %}style="display: none;"{% endif %}>
            </div>
          </div>
          {% endif %}
          <div class="post-content">
            <div class="post-text" data-quill-content="{{ item.description | dump | safe }}"></div>
            <div class="post-footer">
              <div class="post-meta">{{ item.date }}</div>
              {% if item.tags %}
              <div class="post-tags">
                {% for tag in item.tags %}
                <button class="tag-button" onclick="searchByTag('{{ tag }}')">#{{ tag }}</button>
                {% endfor %}
              </div>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
      
      <!-- Dynamic posts (loaded via JavaScript) -->
      <div id="dynamic-posts"></div>
    </div>
  </section>
  
  <!-- Inject Eleventy posts data as JavaScript variable -->
  <script>
    window.eleventyPosts = {{ postsData.posts | dump | safe }};
  </script>
  
  <!-- Tokens are safely injected via JavaScript -->
</section>


<!-- Post management helper script -->
<script src="/js/posts-manager.js"></script>


