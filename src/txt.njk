---
layout: layout.njk
title: "글"
description: "텍스트 포스트들을 확인하세요."
lang: "en"
permalink: "/txt.html"
---

<section id="content">
  <h2>{{ i18n.txt.title | t(lang) }}</h2>
  
  <div class="post-list" id="post-list">
    <!-- 정적 포스트들 (빌드 시점) -->
    {% for item in posts.posts %}
      <div class="post-item">
        {% if item.image %}
        <div class="post-image">
          {{ item.image | dualImage | safe }}
          <div class="image-placeholder" {% if item.image %}style="display: none;"{% endif %}>
          </div>
        </div>
        {% endif %}
        <div class="post-content">
          <div class="post-text" data-quill-content="{{ item.description | dump | safe }}"></div>
          <div class="post-footer">
            <div class="post-meta">{{ item.date }}</div>
            {% if item.tags %}
            <div class="post-tags">
              {% for tag in item.tags %}
              <button class="tag-button" onclick="searchByTag('{{ tag }}')">#{{ tag }}</button>
              {% endfor %}
            </div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
    
    <!-- 동적 포스트들 (JavaScript로 로드) -->
    <div id="dynamic-posts"></div>
  </div>
  
  <!-- Eleventy posts 데이터를 JavaScript 변수로 주입 -->
  <script>
    window.eleventyPosts = {{ postsData.posts | dump | safe }};
  </script>
  
  <!-- 토큰은 JavaScript에서 안전하게 주입됩니다 -->
</section>

<!-- AdminAuth 클래스 정의 -->
<script>
// AdminAuth 클래스 로드 (login.njk에서 정의된 것과 동일)
class AdminAuth {
  constructor() {
    // 환경변수에서 관리자 키 가져오기 (빌드 시점에 주입됨)
    this.adminKey = '{{ adminSecretKey }}';
    this.sessionKey = 'admin_session';
    this.expiresKey = 'admin_expires';
  }
  
  verifyAdminKey(inputKey) {
    // 관리자 키가 설정되지 않은 경우 로그인 차단
    if (!this.adminKey || this.adminKey.trim() === '') {
      return false;
    }
    
    // 영어 키만 지원
    const trimmedInput = inputKey ? inputKey.trim() : '';
    const trimmedAdminKey = this.adminKey.trim();
    
    return trimmedInput === trimmedAdminKey;
  }
  
  setAdminSession() {
    const sessionToken = this.generateSessionToken();
    const expires = Date.now() + (24 * 60 * 60 * 1000); // 24시간
    
    localStorage.setItem(this.sessionKey, sessionToken);
    localStorage.setItem(this.expiresKey, expires.toString());
    
    return sessionToken;
  }
  
  generateSessionToken() {
    const timestamp = Date.now();
    const random = Math.random().toString(36).substring(2);
    return btoa(`${timestamp}_${random}_ADMIN`).replace(/[+/=]/g, '');
  }
  
  isAdminLoggedIn() {
    const session = localStorage.getItem(this.sessionKey);
    const expires = localStorage.getItem(this.expiresKey);
    
    if (!session || !expires) return false;
    if (Date.now() > parseInt(expires)) {
      this.logout();
      return false;
    }
    return true;
  }
  
  logout() {
    localStorage.removeItem(this.sessionKey);
    localStorage.removeItem(this.expiresKey);
  }
}

// 전역으로 사용할 수 있도록 설정
window.AdminAuth = AdminAuth;
</script>

<!-- Admin 모드 확인 스크립트 -->
<script>
  // Admin 모드 확인
  function checkAdminMode() {
    if (typeof AdminAuth !== 'undefined') {
      const adminAuth = new AdminAuth();
      const isLoggedIn = adminAuth.isAdminLoggedIn();
      
      if (isLoggedIn) {
        window.isAdminMode = true;
        document.body.classList.add('admin-mode');
        console.log('Admin 모드가 활성화되었습니다.');
      } else {
        window.isAdminMode = false;
        document.body.classList.remove('admin-mode');
        console.log('로그인이 필요합니다. 삭제 버튼이 숨겨집니다.');
      }
    } else {
      window.isAdminMode = false;
      document.body.classList.remove('admin-mode');
      console.log('AdminAuth 클래스를 찾을 수 없습니다.');
    }
  }
  
  // 페이지 로드 시 admin 모드 확인
  document.addEventListener('DOMContentLoaded', checkAdminMode);
</script>

<!-- 포스트 관리 헬퍼 스크립트 -->
<script src="/js/posts-manager.js"></script>

<!-- Admin 모드 스타일 -->
<style>
  .admin-mode .admin-buttons {
    display: inline-block;
    margin-left: 10px;
  }
  
  .admin-buttons {
    display: none;
  }
  
  .delete-btn {
    background: #ff4444;
    color: white;
    border: none;
    border-radius: 3px;
    padding: 2px 6px;
    font-size: 12px;
    cursor: pointer;
    transition: background-color 0.2s;
  }
  
  .delete-btn:hover {
    background: #cc0000;
  }
  
  .admin-mode .post-item {
    position: relative;
  }
  
  .admin-mode .post-footer {
    position: relative;
  }
</style>

