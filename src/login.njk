<section id="content">
  <h2>{{ i18n.login.title | t(lang) }}</h2>
  
  <div class="login-container">
    <div class="login-form">
      <div class="form-group">
        <label for="admin-key">관리자 키</label>
        <input type="text" id="admin-key" class="form-input" placeholder="Enter admin key" pattern="[a-zA-Z0-9!@#$%^&*()_+\-=\[\]{};':&quot;\\|,.<>\/?]*" oninput="this.value = this.value.replace(/[^a-zA-Z0-9!@#$%^&*()_+\-=\[\]{};':&quot;\\|,.<>\/?]/g, '')" />
        <small class="form-help">환경변수에서 관리자 키를 가져옵니다.</small>
      </div>
      
      <div class="form-actions">
        <button id="login-btn" class="button">로그인</button>
        <button id="cancel-btn" class="button secondary">취소</button>
      </div>
    </div>
  </div>
</section>

