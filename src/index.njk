layout: layout.njk
title: It''s a Wonderful World
description: A lovingly preserved Sailor Moon fan shrine in glorious 1998 style.
scripts:
  - |
      document.addEventListener("DOMContentLoaded", () => {
        const ticker = [
          "Site refreshed: Sept 24, 2024",
          "Best viewed in Netscape Navigator 4.7!",
          "You are visitor #" + Math.floor(Math.random() * 900000 + 100000)
        ];
        let idx = 0;
        setInterval(() => {
          window.status = ticker[idx % ticker.length];
          idx += 1;
        }, 2200);
      });
