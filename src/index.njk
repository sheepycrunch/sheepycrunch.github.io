---
layout: layout.njk
title: "dakimakura"
description: "dakimakura - 개인 블로그"
showNavigation: true
css: "/style.css"
lang: "kr"
---

<!-- 아이콘 쇼케이스 섹션 -->
<section id="icon-showcase">
  <ol>
    <li><img src="{{ '/images/icons/icon1.png' | neocitiesImage }}" alt="icon" onerror="this.style.display='none'"></li>
    <li class="hidden"><img src="{{ '/images/icons/icon2.png' | neocitiesImage }}" alt="icon" onerror="this.style.display='none'"></li>
    <li class="hidden"><img src="{{ '/images/icons/icon3.png' | neocitiesImage }}" alt="icon" onerror="this.style.display='none'"></li>
    <li class="hidden"><img src="{{ '/images/icons/icon4.png' | neocitiesImage }}" alt="icon" onerror="this.style.display='none'"></li>
    <li class="hidden"><img src="{{ '/images/icons/icon5.png' | neocitiesImage }}" alt="icon" onerror="this.style.display='none'"></li>
  </ol>
  <img id="misuzu-button" class="clickable" src="{{ '/images/button.png' | neocitiesImage }}" alt="click to change icon" onerror="this.style.display='none'">
</section>

<!-- 자기소개 섹션 -->
<!-- <section>
  <table>
    <tr>
      <th><font dir="auto" style="vertical-align: inherit;"><font dir="auto" style="vertical-align: inherit;">{{ i18n.author.name | t(lang) }}</font></font></th>
      <td><span class="fn nickname" itemprop="name"><font dir="auto" style="vertical-align: inherit;"><font dir="auto" style="vertical-align: inherit;">{{ site.author.name }}</font></font></span></td>
    </tr>
  </table>
</section> -->

<!-- 사이트 소개 섹션 -->
<section>
  <h2>{{ i18n.sections.aboutSite }}</h2>
  <p>{{ i18n.author.introduction }}</p>
  <p>{{ i18n.aboutSite.text }}</p>
</section>

<!-- 콘텐츠 섹션 -->
<section>
  <h2>{{ i18n.sections.content }}</h2>
  <ul class="vertical-layout">
    {% for nav in site.navigation %}
    <li>
      <a href="{{ nav.url | localizedUrl(lang) }}" class="text-button" 
         {% if nav.name == "write" %}id="write-link" style="display: none;"{% endif %}>
        {% if nav.name == "write" %}
          {{ i18n.write.title }}
        {% elif nav.name == "txt" %}
          {{ i18n.txt.title }}
        {% elif nav.name == "gallery" %}
          {{ i18n.gallery.title }}
        {% elif nav.name == "archive" %}
          {{ i18n.archive.title }}
        {% elif nav.name == "search" %}
          {{ i18n.search.title }}
        {% else %}
          {{ nav.name }}
        {% endif %}
      </a>
    </li>
    {% endfor %}
  </ul>
</section>

<!-- SNS 링크 섹션 -->
<section>
  <h2>{{ i18n.sections.snsLinks }}</h2>
  <ul class="horizontal-layout">
    {% if site.social.twitter %}
    <li>
      <a href="{{ site.social.twitter }}" target="_blank">
        <img src="{{ '/images/social/twitter.png' | neocitiesImage }}" alt="Twitter" class="link-icon clickable" onerror="this.style.display='none'">
      </a>
    </li>
    {% endif %}
    {% if site.social.github %}
    <li>
      <a href="{{ site.social.github }}" target="_blank">
        <img src="{{ '/images/social/github.png' | neocitiesImage }}" alt="GitHub" class="link-icon clickable" onerror="this.style.display='none'">
      </a>
    </li>
    {% endif %}
    {% if site.social.pixiv %}
    <li>
      <a href="{{ site.social.pixiv }}" target="_blank">
        <img src="{{ '/images/social/pixiv.png' | neocitiesImage }}" alt="Pixiv" class="link-icon clickable" onerror="this.style.display='none'">
      </a>
    </li>
    {% endif %}
  </ul>
</section>

<!-- 사이트 통계 -->
<section class="site-stats">
  <p id="site-stats">{{ i18n.stats.posts }}: {{ realPostCount }}, {{ i18n.stats.visitors }}: {{ site.stats.visitors }}, {{ i18n.stats.lastUpdate }}: <span id="last-update">Loading...</span></p>
</section>

<!-- JavaScript 파일들 -->
<script src="/js/stats-manager.js" onerror="console.warn('stats-manager.js 로딩 실패')"></script>
<script src="/js/icon-changer.js" onerror="console.warn('icon-changer.js 로딩 실패')"></script>
<script src="/js/admin-panel.js" onerror="console.warn('admin-panel.js 로딩 실패')"></script>

<script>
// 관리자 권한 체크 및 UI 제어
document.addEventListener('DOMContentLoaded', function() {
  // AdminAuth 클래스가 정의되어 있는지 확인
  if (typeof AdminAuth !== 'undefined') {
    const adminAuth = new AdminAuth();
    
    // 관리자 로그인 상태에 따라 글쓰기 링크 표시/숨김
    const writeLink = document.getElementById('write-link');
    if (writeLink) {
      if (adminAuth.isAdminLoggedIn()) {
        writeLink.style.display = 'block';
      } else {
        writeLink.style.display = 'none';
      }
    }
  } else {
    // AdminAuth가 로드되지 않은 경우 글쓰기 링크 숨김
    const writeLink = document.getElementById('write-link');
    if (writeLink) {
      writeLink.style.display = 'none';
    }
  }
});
</script>