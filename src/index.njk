---
layout: layout.njk
title: "DIY Hamster Dungeon"
description: "DIY Hamster Dungeon - 개인 블로그"
showNavigation: true
css: "/index.css"
---

<!-- 아이콘 쇼케이스 섹션 -->
<section id="icon-showcase">
  <ol>
    <li><img src="/images/icons/icon1.png" alt="icon" onerror="this.style.display='none'"></li>
    <li class="hidden"><img src="/images/icons/icon2.png" alt="icon" onerror="this.style.display='none'"></li>
    <li class="hidden"><img src="/images/icons/icon3.png" alt="icon" onerror="this.style.display='none'"></li>
    <li class="hidden"><img src="/images/icons/icon4.png" alt="icon" onerror="this.style.display='none'"></li>
    <li class="hidden"><img src="/images/icons/icon5.png" alt="icon" onerror="this.style.display='none'"></li>
  </ol>
  <img id="misuzu-button" class="clickable" src="/images/button.png" alt="click to change icon" onerror="this.style.display='none'">
</section>

<!-- 자기소개 섹션 -->
<section>
  <h2>자기소개</h2>
  <dl id="name-display">
    <dt>이름</dt>
    <dd>{{ site.author.name }}</dd>
  </dl>
  <p>{{ site.author.introduction }}</p>
  <p>주요 취미: {{ site.author.hobbies | join(', ') }}</p>
  <p>{{ site.author.currentProject }}</p>
</section>

<!-- 사이트 소개 섹션 -->
<section>
  <h2>이 사이트에 대해</h2>
  <p>2024년 현재, 전반적으로 새롭게 만들고 싶지만 작업이 전혀 진행되지 않고 있습니다.</p>
  <p>이 사이트의 내용도 그다지 업데이트하지 못해서 정말 죄송합니다.</p>
</section>

<!-- SNS 링크 섹션 -->
<section>
  <h2>각 SNS 링크</h2>
  <ul class="horizontal-layout">
    {% if site.social.twitter %}
    <li>
      <a href="{{ site.social.twitter }}" target="_blank">
        <img src="/images/social/twitter.png" alt="Twitter" class="link-icon clickable" onerror="this.style.display='none'">
      </a>
    </li>
    {% endif %}
    {% if site.social.github %}
    <li>
      <a href="{{ site.social.github }}" target="_blank">
        <img src="/images/social/github.png" alt="GitHub" class="link-icon clickable" onerror="this.style.display='none'">
      </a>
    </li>
    {% endif %}
    {% if site.social.pixiv %}
    <li>
      <a href="{{ site.social.pixiv }}" target="_blank">
        <img src="/images/social/pixiv.png" alt="Pixiv" class="link-icon clickable" onerror="this.style.display='none'">
      </a>
    </li>
    {% endif %}
  </ul>
</section>

<!-- 콘텐츠 섹션 -->
<section>
  <h2>콘텐츠</h2>
  <ul class="horizontal-layout">
    {% for nav in site.navigation %}
    <li>
      <a href="{{ nav.url }}">
        <div class="clickable button-like-decoration">
          <p>{{ nav.name }}</p>
        </div>
      </a>
    </li>
    {% endfor %}
  </ul>
</section>

<!-- 통계 정보 섹션 -->
<section>
  <h2>사이트 정보</h2>
  <div class="info-stats">
    <div class="stat-item">
      <span class="stat-label">포스트:</span>
      <span class="stat-value">{{ site.stats.posts }}</span>
    </div>
    <div class="stat-item">
      <span class="stat-label">방문자:</span>
      <span class="stat-value">{{ site.stats.visitors }}</span>
    </div>
    <div class="stat-item">
      <span class="stat-label">마지막 업데이트:</span>
      <span class="stat-value">{{ site.stats.lastUpdate }}</span>
    </div>
  </div>
</section>

<!-- 최신 업데이트 섹션 -->
<section>
  <h2>최신 업데이트</h2>
    <div class="update-list">
      <div class="update-item">
        <span class="update-date">2024.01.15</span>
        <span class="update-text">새로운 갤러리 업데이트!</span>
      </div>
      <div class="update-item">
        <span class="update-date">2024.01.10</span>
        <span class="update-text">블로그 디자인 개선</span>
      </div>
      <div class="update-item">
        <span class="update-date">2024.01.05</span>
        <span class="update-text">첫 번째 포스트 작성</span>
      </div>
    </div>
</section>

<!-- 기능 소개 섹션 -->
<section>
  <h2>주요 기능</h2>
    <div class="feature-list">
    {% for feature in site.features %}
      <div class="feature-item">
      <span class="feature-icon">{{ feature.icon }}</span>
      <span class="feature-title">{{ feature.title }}</span>
      <span class="feature-desc">{{ feature.description }}</span>
    </div>
    {% endfor %}
  </div>
</section>

<!-- 방문자 메시지 -->
<section class="visitor-message">
  <h3>방문해주셔서 감사합니다</h3>
  <p>DIY Hamster Dungeon에 오신 것을 환영합니다! 자유롭게 둘러보시고 즐거운 시간 보내세요!</p>
  <div class="message-actions">
    <a href="/contact" class="button">메시지 보내기</a>
    <a href="/gallery" class="button secondary">갤러리 보기</a>
  </div>
</section>

<!-- JavaScript 파일들 -->
<script src="/js/icon-changer.js"></script>
<script src="/js/stats-manager.js"></script>
<script src="/js/admin-panel.js"></script>