---
layout: layout.njk
title: "갤러리"
description: "갤러리 이미지들을 확인하세요."
lang: "en"
permalink: "/gallery.html"
---

<section id="content">
  <section data-editable data-name="gallery-header">
    <h2>Gallery</h2>
  </section>
  
  <div class="gallery-content">
    <section data-editable data-name="gallery-intro">
      <div class="gallery-intro">
        <p>Image gallery. Click on each image to view in detail.</p>
      </div>
    </section>
    
    <section data-editable data-name="gallery-grid">
      <div class="gallery-grid">
      {% for item in posts.posts %}
        <div class="gallery-item">
          {% if item.image %}
          <img src="{{ item.image }}" alt="{{ item.description }}" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
          {% endif %}
          <div class="image-placeholder" {% if item.image %}style="display: none;"{% endif %}>
          </div>
          {% if item.tags %}
          <div class="gallery-tags">
            {% if item.description %}
            <div class="gallery-description" data-quill-content="{{ item.description | dump | safe }}"></div>
            {% endif %}
            <div class="tag-list">
              {% for tag in item.tags %}
              <button class="tag-button" onclick="searchByTag('{{ tag }}')">#{{ tag }}</button>
              {% endfor %}
            </div>
          </div>
          {% endif %}
        </div>
      {% endfor %}
      </div>
    </section>
  </div>
</section>

<script>
// Convert Quill Delta to HTML (same function as txt.njk)
function convertQuillToHtml(quillContent) {
  // If null or undefined
  if (!quillContent) {
    return '<p>No content available.</p>';
  }
  
  // If string, return as is
  if (typeof quillContent === 'string') {
    return quillContent.replace(/\n/g, '<br>');
  }
  
  // If not object, convert to JSON
  if (typeof quillContent !== 'object') {
    return String(quillContent).replace(/\n/g, '<br>');
  }
  
  // If not Quill Delta format, display as JSON
  if (!quillContent.ops || !Array.isArray(quillContent.ops)) {
    return '<pre>' + JSON.stringify(quillContent, null, 2) + '</pre>';
  }
  
  let html = '';
  
  try {
    quillContent.ops.forEach(op => {
      if (op && op.insert) {
        if (typeof op.insert === 'string') {
          let text = op.insert;
          
          // Handle line breaks
          text = text.replace(/\n/g, '<br>');
          
          // Apply styles
          if (op.attributes) {
            if (op.attributes.bold) text = `<strong>${text}</strong>`;
            if (op.attributes.italic) text = `<em>${text}</em>`;
            if (op.attributes.underline) text = `<u>${text}</u>`;
            if (op.attributes.strike) text = `<s>${text}</s>`;
            
            // Handle headers
            if (op.attributes.header) {
              const level = op.attributes.header;
              text = `<h${level}>${text}</h${level}>`;
            }
            
            // Handle colors
            if (op.attributes.color) {
              text = `<span style="color: ${op.attributes.color}">${text}</span>`;
            }
            if (op.attributes.background) {
              text = `<span style="background-color: ${op.attributes.background}">${text}</span>`;
            }
          }
          
          html += text;
        } else if (op.insert && typeof op.insert === 'object' && op.insert.image) {
          // Handle images
          html += `<img src="${op.insert.image}" alt="Image" style="max-width: 100%; height: auto;">`;
        }
      }
    });
  } catch (error) {
    console.error('Quill conversion error:', error);
    return '';
  }
  
  // Handle empty content
  if (!html.trim()) {
    html = '';
  }
  
  return html;
}

// Convert Quill content of static posts
function convertStaticPosts() {
  const staticPosts = document.querySelectorAll('.gallery-description[data-quill-content]');
  staticPosts.forEach(postElement => {
    const quillData = postElement.getAttribute('data-quill-content');
    if (quillData) {
      try {
        const quillContent = JSON.parse(quillData);
        const html = convertQuillToHtml(quillContent);
        postElement.innerHTML = html;
        postElement.removeAttribute('data-quill-content');
      } catch (error) {
        console.error('Static post conversion error:', error);
        postElement.innerHTML = '';
      }
    }
  });
}

// Convert static posts on page load
document.addEventListener('DOMContentLoaded', function() {
  convertStaticPosts();
});

function searchByTag(tag) {
  // Navigate to search page or filter on current page
  window.location.href = `/search.html?q=${encodeURIComponent(tag)}`;
}
</script>

