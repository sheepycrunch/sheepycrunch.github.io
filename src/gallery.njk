---
layout: layout.njk
title: "{{ i18n_kr.gallery.title | t(lang) }}"
description: "{{ i18n_kr.gallery.description | t(lang) }}"
lang: "kr"
---

<section>
  <h1>{{ i18n_kr.gallery.title | t(lang) }}</h1>
  
  <div class="gallery-grid">
    {% for item in posts.posts %}
      {% if item.category == "gallery" %}
      <div class="gallery-item">
        {% if item.image %}
        <img src="{{ item.image }}" alt="{{ item.description }}" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
        {% endif %}
        <div class="image-placeholder" {% if item.image %}style="display: none;"{% endif %}>
        </div>
        {% if item.tags %}
        <div class="gallery-tags">
          {% if item.description %}
          <div class="gallery-description">{{ item.description }}</div>
          {% endif %}
          <div class="tag-list">
            {% for tag in item.tags %}
            <button class="tag-button" onclick="searchByTag('{{ tag }}')">#{{ tag }}</button>
            {% endfor %}
          </div>
        </div>
        {% endif %}
      </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

