---
layout: layout.njk
title: "{{ i18n_kr.sections.siteInfo | t(lang) }}"
description: "{{ i18n_kr.sections.siteInfo | t(lang) }}"
lang: "kr"
---

<section>
  <h1>{{ i18n_kr.sections.siteInfo | t(lang) }}</h1>
  <p>{{ i18n_kr.aboutSite.text1 | t(lang) }}</p>
  
  <div class="archive-timeline">
    {% for timeline in archive.timeline %}
    <div class="timeline-item">
      <div class="timeline-date">{{ timeline.year }}년 {{ timeline.month }}월</div>
      <div class="timeline-content">
        <h3>{{ timeline.month }}월 {{ timeline.date }}일</h3>
        <ul>
          {% for event in timeline.events %}
          <li>
            {% if event.url %}
            <a href="{{ event.url }}">{{ event.description }}</a>
            {% else %}
            {{ event.description }}
            {% endif %}
            <span class="event-type">{{ event.type }}</span>
          </li>
          {% endfor %}
        </ul>
      </div>
    </div>
    {% endfor %}
  </div>
</section>

<style>
.archive-timeline {
  margin-top: var(--spacing-xl);
  position: relative;
  padding-left: var(--spacing-xl);
}

.archive-timeline::before {
  content: '';
  position: absolute;
  left: var(--spacing-lg);
  top: 0;
  bottom: 0;
  width: 2px;
  background: var(--border-light);
}

.timeline-item {
  position: relative;
  margin-bottom: var(--spacing-3xl);
  padding-left: var(--spacing-xl);
}

.timeline-item::before {
  content: '';
  position: absolute;
  left: -var(--spacing-lg);
  top: var(--spacing-sm);
  width: 12px;
  height: 12px;
  background: var(--accent-primary);
  border-radius: 50%;
  border: 3px solid var(--bg-primary);
}

.timeline-date {
  font-weight: bold;
  color: var(--accent-primary);
  margin-bottom: var(--spacing-sm);
  font-size: var(--font-size-large);
}

.timeline-content h3 {
  margin: 0 0 var(--spacing-sm) 0;
  color: var(--text-primary);
  font-size: var(--font-size-base);
}

.timeline-content ul {
  margin: 0;
  padding-left: var(--spacing-lg);
}

.timeline-content li {
  margin-bottom: var(--spacing-xs);
  color: var(--text-secondary);
}

.timeline-content a {
  color: var(--accent-primary);
  text-decoration: none;
}

.timeline-content a:hover {
  color: var(--accent-secondary);
}

.event-type {
  background: var(--bg-tertiary);
  color: var(--text-secondary);
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--border-radius-sm);
  font-size: var(--font-size-small);
  margin-left: var(--spacing-sm);
}
</style>
