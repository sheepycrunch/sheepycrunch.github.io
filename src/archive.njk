---
layout: layout.njk
title: "아카이브"
description: "아카이브된 포스트들을 확인하세요."
lang: "kr"
permalink: "/archive.html"
---

<section id="content">
  <h2>{{ i18n.archive.title | t(lang) }}</h2>
  
  <div class="archive-list">
    {% for item in posts.posts %}
      {% if item.category == "archive" %}
      <div class="archive-item">
        <div class="archive-thumbnail">
          {% if item.image %}
          <img src="{{ item.image }}" alt="{{ item.description }}" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
          {% endif %}
          <div class="thumbnail-placeholder" {% if item.image %}style="display: none;"{% endif %}>
          </div>
        </div>
        <div class="archive-content">
          <h3><a href="{{ item.description }}" class="archive-page-link" target="_blank">{{ item.description }}</a></h3>
          <div class="archive-tags">
            {% for tag in item.tags %}
            <button class="tag-button" onclick="searchByTag('{{ tag }}')">#{{ tag }}</button>
            {% endfor %}
          </div>
        </div>
      </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

