---
layout: layout.njk
title: "Links"
description: "Useful links are collected here."
lang: "en"
permalink: "/archive.html"
---

<section id="content">
  <section data-editable data-name="archive-header">
    <h2>Links</h2>
  </section>
  
  <div class="archive-content">
    <section data-editable data-name="archive-intro">
      <div class="archive-intro">
        <p>Archive of all posts. Sorted chronologically.</p>
      </div>
    </section>
    
    <section data-editable data-name="archive-list">
      <div class="archive-list">
      {% for item in posts.posts %}
        <div class="archive-item">
          <div class="archive-thumbnail">
            {% if item.image %}
            <img src="{{ item.image }}" alt="{{ item.description }}" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
            {% endif %}
            <div class="thumbnail-placeholder" {% if item.image %}style="display: none;"{% endif %}>
            </div>
          </div>
          <div class="archive-content">
            <h3><a href="#" class="archive-page-link" target="_blank" data-quill-content="{{ item.description | dump | safe }}"></a></h3>
            <div class="archive-tags">
              {% for tag in item.tags %}
              <button class="tag-button" onclick="searchByTag('{{ tag }}')">#{{ tag }}</button>
              {% endfor %}
            </div>
          </div>
        </div>
      {% endfor %}
      </div>
    </section>
  </div>
</section>

