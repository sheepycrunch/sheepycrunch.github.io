<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>페이지를 찾을 수 없습니다</title>
  <link rel="icon" href="/favicon.png">
  <link href="/css/reset.css" rel="stylesheet" type="text/css" media="all">
  <link href="/style.css" rel="stylesheet" type="text/css" media="all">
</head>
<body>
  <div class="error-container">
    <div class="error-image">
      <img src="{{ neocitiesUrl }}/images/1998/cloud-header.png" 
           alt="404 Error" />
    </div>
    <div class="error-buttons">
      <a href="/" class="error-button">
        <img src="{{ neocitiesUrl }}/images/1998/bubble-on.gif" 
             alt="메인으로" />
      </a>
    </div>
  </div>

  <style>
  .error-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 2rem;
    background: var(--bg-color, #f0f0f0);
  }

  .error-image img {
    max-width: 100%;
    height: auto;
    margin-bottom: 2rem;
  }

  .error-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .error-button {
    display: inline-block;
    transition: var(--transition-fast);
  }

  .error-button:hover {
    transform: translateY(-2px);
  }

  .error-button img {
    width: 80px;
    height: auto;
    border: none;
  }
  </style>
</body>
</html>
