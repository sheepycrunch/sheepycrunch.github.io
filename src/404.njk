---
layout: layout.njk
title: "페이지를 찾을 수 없습니다"
description: "요청하신 페이지가 존재하지 않거나 이동되었습니다."
refresh: "5;url=/"
---

<nav class="section" id="error" aria-label="오류 섹션">
  <div class="highlight_logo">
    <div class="highlight">
      <h2><span title="error" lang="ko">오류</span> / <small>404 Not Found</small></h2>
    </div>
  </div>
  <div id="errorcontent">
    <h3>페이지를 찾을 수 없습니다</h3>
    <p>요청하신 페이지가 존재하지 않거나 이동되었습니다.</p>
    <p>5초 후 자동으로 메인 페이지로 이동합니다.</p>
    <p><a href="/">메인 페이지로 바로 이동</a></p>
    
    <h3>사용 가능한 페이지</h3>
    <ul>
      {% for item in site.navigation %}
      <li><a href="{{ item.url }}">{{ item.title }}</a></li>
      {% endfor %}
    </ul>
  </div>
</nav>

{% set scripts %}
// 5초 후 자동 리디렉션
setTimeout(function() {
  window.location.href = '/';
}, 5000);

// 카운트다운 표시
let countdown = 5;
const countdownElement = document.createElement('p');
countdownElement.id = 'countdown';
countdownElement.style.fontWeight = 'bold';
countdownElement.style.color = '#000';
countdownElement.style.backgroundColor = '#fff';
countdownElement.style.padding = '5px';
countdownElement.style.display = 'inline-block';
document.getElementById('errorcontent').appendChild(countdownElement);

const countdownInterval = setInterval(function() {
  countdown--;
  countdownElement.textContent = countdown + '초 후 메인 페이지로 이동합니다...';
  if (countdown <= 0) {
    clearInterval(countdownInterval);
  }
}, 1000);
{% endset %}
