---
layout: layout.njk
title: "dakimakura"
description: "dakimakura - 개인 블로그"
showNavigation: true
css: "/style.css"
lang: "en"
---

<!-- 아이콘 쇼케이스 섹션 -->
<section id="icon-showcase">
  <ol>
    <li>{{ '/images/icons/icon1.png' | dualImage | safe }}</li>
    <li class="hidden">{{ '/images/icons/icon2.png' | dualImage | safe }}</li>
    <li class="hidden">{{ '/images/icons/icon3.png' | dualImage | safe }}</li>
    <li class="hidden">{{ '/images/icons/icon4.png' | dualImage | safe }}</li>
    <li class="hidden">{{ '/images/icons/icon5.png' | dualImage | safe }}</li>
  </ol>
  <div id="misuzu-button" class="clickable">{{ '/images/button.png' | dualImage | safe }}</div>
</section>

<!-- 자기소개 섹션 -->
<!-- <section>
  <table>
    <tr>
      <th><font dir="auto" style="vertical-align: inherit;"><font dir="auto" style="vertical-align: inherit;">{{ i18n.author.name | t(lang) }}</font></font></th>
      <td><span class="fn nickname" itemprop="name"><font dir="auto" style="vertical-align: inherit;"><font dir="auto" style="vertical-align: inherit;">{{ site.author.name }}</font></font></span></td>
    </tr>
  </table>
</section> -->

<!-- 사이트 소개 섹션 -->
<section>
  <h2>{{ i18n.sections.aboutSite | autoTranslate("en") }}</h2>
  <p>{{ i18n.author.introduction | autoTranslate("en") }}</p>
  <p>{{ i18n.aboutSite.text | autoTranslate("en") }}</p>
</section>

<!-- 콘텐츠 섹션 -->
<section>
  <h2>{{ i18n.sections.content | autoTranslate("en") }}</h2>
  <ul class="vertical-layout">
    {% for nav in site.navigation %}
    <li>
      <a href="{{ nav.url | localizedUrl(lang) }}" class="text-button" 
         {% if nav.name == "write" %}id="write-link" style="display: none;"{% endif %}>
        {% if nav.name == "txt" %}
          {{ i18n.txt.title | autoTranslate("en") }}
        {% elif nav.name == "gallery" %}
          {{ i18n.gallery.title | autoTranslate("en") }}
        {% elif nav.name == "links" %}
          {{ i18n.links.title | autoTranslate("en") }}
        {% elif nav.name == "search" %}
          {{ i18n.search.title | autoTranslate("en") }}
        {% elif nav.name == "write" %}
          {{ i18n.write.title | autoTranslate("en") }}
        {% else %}
          {{ nav.name }}
        {% endif %}
      </a>
    </li>
    {% endfor %}
  </ul>
</section>

<!-- 배너 섹션 -->
<section>
  <h2>{{ i18n.banners.title | autoTranslate("en") }}</h2>
  <div class="banner-section">
    <div class="banner-item">
      <div class="banner-image">{{ '/neocities.png' | dualImage | safe }}</div>
      <p class="banner-description">{{ i18n.banners.description | autoTranslate("en") }}</p>
    </div>
  </div>
</section>

<!-- 사이트 통계 -->
<section class="site-stats">
  <p id="site-stats">{{ i18n.stats.posts | autoTranslate("en") }}: {{ realPostCount }}, {{ i18n.stats.visitors | autoTranslate("en") }}: {{ site.stats.visitors }}, {{ i18n.stats.lastUpdate | autoTranslate("en") }}: <span id="last-update">Loading...</span></p>
</section>

<!-- JavaScript 파일들 -->
<script src="/js/stats-manager.js" onerror="console.warn('stats-manager.js 로딩 실패')"></script>
<script src="/js/icon-changer.js" onerror="console.warn('icon-changer.js 로딩 실패')"></script>
<script src="/js/admin-panel.js" onerror="console.warn('admin-panel.js 로딩 실패')"></script>

<script>
// 관리자 권한 체크 및 UI 제어
document.addEventListener('DOMContentLoaded', function() {
  // AdminAuth 클래스가 정의되어 있는지 확인
  if (typeof AdminAuth !== 'undefined') {
    const adminAuth = new AdminAuth();
    
    // 관리자 로그인 상태에 따라 글쓰기 링크 표시/숨김
    const writeLink = document.getElementById('write-link');
    if (writeLink) {
      if (adminAuth.isAdminLoggedIn()) {
        writeLink.style.display = 'block';
      } else {
        writeLink.style.display = 'none';
      }
    }
  } else {
    // AdminAuth가 로드되지 않은 경우 글쓰기 링크 숨김
    const writeLink = document.getElementById('write-link');
    if (writeLink) {
      writeLink.style.display = 'none';
    }
  }
});
</script>
